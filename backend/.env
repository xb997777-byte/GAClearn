# Fill in your local AI configuration here before starting the backend.
# This file is loaded automatically by manage.py / wsgi.py / asgi.py.

# DeepSeek API key
AI_API_KEY=sk-10c4971b1a6b4dec87e07573b4c825cb

# Faster DeepSeek model for real-time grammar analysis
AI_MODEL=deepseek-v4-flash

# DeepSeek OpenAI-compatible base URL
AI_BASE_URL=https://api.deepseek.com

# -----------------------------
# RAG / Embedding configuration
# -----------------------------

# Embedding backend selection:
# - auto: prefer online embedding if configured, otherwise try local sentence-transformers, then hash fallback
# - online: force remote embedding API
# - sentence_transformers: force local sentence-transformers model
# - hash: force local hash embedding
AI_EMBEDDING_BACKEND=auto

# Embedding provider type:
# - openai_compatible: OpenAI-compatible embeddings endpoint
AI_EMBEDDING_PROVIDER=openai_compatible

# Embedding API key for the vector / embedding model provider
AI_EMBEDDING_API_KEY='sk-5938adc0ab794cbfa27a789aab6b7a1e'

# Embedding model name, for example: text-embedding-3-small
AI_EMBEDDING_MODEL=text-embedding-v4

# Embedding base URL, for example: https://api.openai.com/v1
AI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional request timeout in seconds for embedding API calls
AI_EMBEDDING_TIMEOUT_SECONDS=40

# Optional batch size per embeddings API request
AI_EMBEDDING_API_BATCH_SIZE=8

# Optional local sentence-transformers model name when using local embedding
AI_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional hash embedding dimension when falling back to local hash embedding
AI_HASH_EMBEDDING_DIM=512

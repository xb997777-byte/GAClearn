# Copy this file to .env and fill in your own local values.

AI_API_KEY=your_deepseek_api_key_here
AI_MODEL=deepseek-v4-flash
AI_THINKING_MODE=disabled
AI_BASE_URL=https://api.deepseek.com
REDIS_URL=redis://127.0.0.1:6379/0
AI_AGENT_RUNTIME_MODE=celery
AI_AGENT_INLINE_RECORDING=true
AI_AGENT_REQUIRE_APPROVAL_FOR_MUTATIONS=true
AI_AGENT_QUEUE_SHORT=ai_short
AI_AGENT_QUEUE_LONG=ai_long
AI_AGENT_QUEUE_TOOLS=ai_tools
CELERY_TASK_ALWAYS_EAGER=false

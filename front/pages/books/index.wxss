@import "../../styles/theme.wxss";

.search-bar {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 24rpx;
}

.search-field {
  flex: 1;
  display: flex;
  align-items: center;
  min-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: var(--theme-card-bg);
  border: 2rpx solid var(--theme-card-border);
  box-sizing: border-box;
}

.search-field-icon {
  flex-shrink: 0;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  font-size: var(--theme-font-size-base);
  color: var(--theme-text-primary);
}

.search-btn {
  flex-shrink: 0;
  min-width: 144rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--theme-primary-start) 0%, var(--theme-primary-end) 100%);
  color: #ffffff;
  font-size: var(--theme-font-size-button);
  font-weight: 700;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-block {
  margin-top: 24rpx;
}

.filter-title {
  font-size: var(--theme-font-size-list-desc);
  font-weight: 700;
  color: var(--theme-text-primary);
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}

.filter-chip {
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: var(--theme-ghost-bg);
  border: 2rpx solid var(--theme-card-border);
  color: var(--theme-text-secondary);
  font-size: var(--theme-font-size-list-desc);
}

.filter-chip.active {
  background: var(--theme-secondary-bg);
  border-color: var(--theme-accent);
  color: var(--theme-accent);
  font-weight: 700;
}

.filter-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.filter-summary-row .card-subtitle {
  margin-top: 0;
  flex: 1;
}

.filter-clear {
  flex-shrink: 0;
  color: var(--theme-accent);
  font-size: var(--theme-font-size-list-desc);
  font-weight: 700;
}

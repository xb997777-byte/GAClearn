@import "../../styles/theme.wxss";

.learn-page .page-scroll {
  padding-bottom: 176rpx;
}

.learn-bottom-spacer {
  width: 100%;
  height: calc(136rpx + env(safe-area-inset-bottom));
}

.adaptive-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-a), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--theme-page-end) 100%);
}

.adaptive-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.adaptive-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.adaptive-tip {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.hero-reason {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  max-width: 100%;
}

.hero-tag {
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
}

.word-meaning-mask {
  margin-top: 18rpx;
  min-height: 92rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.7;
  box-sizing: border-box;
}

.hero-example-panel {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
}

.hero-example-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-example-label {
  font-size: 24rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
}

.hero-example-audio-btn {
  min-height: 60rpx;
  padding: 0 20rpx;
  border-color: rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 24rpx;
}

.hero-example-text,
.hero-example-translation {
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.75;
}

.hero-example-translation {
  color: rgba(255, 255, 255, 0.82);
}

.hero-stage-tip {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-action-row {
  margin-top: 18rpx;
}

.hero-action-row.tight {
  margin-top: 14rpx;
}

.hero-action-btn,
.hero-decision-btn {
  flex: 1;
}

.hero-ai-entry {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.16);
}

.hero-ai-entry.enabled {
  background: rgba(255, 255, 255, 0.18);
  border-color: rgba(255, 255, 255, 0.28);
}

.hero-ai-entry-kicker {
  font-size: 22rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
}

.hero-ai-entry-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #ffffff;
}

.hero-ai-entry-text {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.9);
}

.hero-ai-entry-actions {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hero-ai-main-btn,
.hero-ai-sub-btn {
  width: 100%;
}

.hero-ai-main-btn {
  background: #ffffff;
  color: var(--theme-secondary-text);
  border: 0;
}

.hero-ai-main-btn::after {
  border: 0;
}

.hero-ai-sub-btn {
  border-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  background: rgba(255, 255, 255, 0.06);
}

.hero-decision-row {
  margin-top: 18rpx;
}

.learn-review-guide-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-b), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--theme-page-end) 100%);
}

.learn-ai-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-b), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--theme-page-end) 100%);
}

.learn-ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.learn-ai-state-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  color: var(--theme-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.learn-ai-state-badge.enabled {
  background: rgba(44, 93, 255, 0.1);
  color: var(--theme-secondary-text);
}

.learn-ai-toolbar {
  margin-top: 18rpx;
  gap: 14rpx;
  flex-wrap: wrap;
}

.ai-refresh-btn {
  flex: 1;
  min-width: 180rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0 26rpx;
  line-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--theme-font-size-button);
  box-sizing: border-box;
}

.ai-refresh-btn::after {
  border: 0;
}

.learn-ai-loading,
.learn-ai-error {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.learn-ai-loading {
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
}

.learn-ai-error {
  background: rgba(183, 28, 28, 0.08);
  color: #b91c1c;
}

.learn-ai-body {
  margin-top: 18rpx;
}

.learn-ai-highlight {
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(44, 93, 255, 0.08) 0%, rgba(120, 156, 255, 0.12) 100%);
}

.learn-ai-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-secondary-text);
}

.learn-ai-text,
.learn-ai-answer-tip {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--theme-text-primary);
  word-break: break-word;
}

.learn-ai-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.learn-ai-note-card,
.learn-ai-why,
.learn-ai-quiz {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid var(--theme-card-border);
  box-shadow: 0 10rpx 24rpx var(--theme-card-shadow);
}

.learn-ai-why,
.learn-ai-quiz {
  margin-top: 18rpx;
}

.learn-ai-option {
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.06);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.learn-ai-answer {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(15, 118, 110, 0.08);
}

ai-evidence {
  display: block;
  margin-top: 18rpx;
}

.learn-review-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
  font-size: 25rpx;
  line-height: 1.7;
}

.learn-review-tag-row {
  margin-top: 16rpx;
}

.learn-review-chip {
  background: #dbeaff;
  color: var(--theme-secondary-text);
}

.learn-review-quick-actions,
.learn-review-secondary-actions {
  margin-top: 16rpx;
  gap: 12rpx;
}

.learn-review-quick-btn {
  flex: 1;
  min-width: 0;
}

.learn-review-secondary-btn {
  flex: 1;
  min-width: 0;
  min-height: 72rpx;
  font-size: 25rpx;
}

.learn-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 0 20rpx calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  pointer-events: none;
}

.learn-bottom-card {
  pointer-events: auto;
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.learn-bottom-actions {
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 28rpx;
  background: rgba(246, 249, 255, 0.92);
  border: 2rpx solid rgba(213, 229, 255, 0.92);
  box-shadow: 0 12rpx 24rpx rgba(13, 110, 253, 0.12);
  backdrop-filter: blur(18rpx);
}

.learn-bottom-btn {
  flex: 1;
  min-width: 0;
  min-height: 76rpx;
  border-radius: 22rpx;
}

@media (max-width: 560px) {
  .learn-ai-grid {
    grid-template-columns: 1fr;
  }

  .hero-example-head {
    flex-direction: column;
    align-items: stretch;
  }

  .learn-bottom-bar {
    padding-left: 16rpx;
    padding-right: 16rpx;
  }

  .learn-review-quick-actions,
  .learn-review-secondary-actions,
  .learn-bottom-actions {
    gap: 10rpx;
  }

  .learn-review-secondary-actions {
    flex-direction: column;
  }

  .learn-review-quick-btn,
  .learn-review-secondary-btn,
  .learn-bottom-btn {
    min-height: 72rpx;
  }
}

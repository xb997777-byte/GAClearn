<view class="page-shell review-page {{themePageClass}}" style="{{pageThemeStyle}}">
  <nav-bar title="复习" showBack="{{true}}" />
  <scroll-view class="page-scroll" scroll-y scroll-into-view="{{scrollIntoViewTarget}}" scroll-with-animation>
    <view wx:if="{{adaptive}}" class="section panel-card adaptive-card">
      <view class="adaptive-header">
        <view>
          <view class="card-title">复习策略</view>
          <view class="card-subtitle">{{ adaptive.mode_label }}</view>
        </view>
        <view class="adaptive-pill">建议 {{ adaptive.recommended_review_word_target }} 词</view>
      </view>
      <view class="adaptive-tip">{{ adaptive.focus_tip }}</view>
    </view>

    <view wx:if="{{hasQuestion}}" id="review-question-anchor" class="section panel-card review-question-card">
      <view class="tag-row">
        <view class="chip-light chip">第 {{ currentIndex + 1 }} 题 / 共 {{ list.length }} 题</view>
        <view wx:if="{{currentQuestion.adaptive_reason}}" class="question-reason">{{ currentQuestion.adaptive_reason }}</view>
      </view>
      <view class="review-question-panel">
        <view wx:if="{{currentQuestion.prompt_label}}" class="review-question-prompt">{{ currentQuestion.prompt_label }}</view>
        <view class="review-question-main review-question-main--{{currentQuestion.presentation_mode}}">
          <view class="review-question-stem review-question-stem--{{currentQuestion.presentation_mode}}">{{ currentQuestion.stem }}</view>
          <view wx:if="{{currentQuestion.helper_role === 'pos' && currentQuestion.helper_text}}" class="review-question-pos-pill">
            {{ currentQuestion.helper_text }}
          </view>
        </view>
        <view wx:if="{{currentQuestion.helper_role === 'translation' && currentQuestion.helper_text}}" class="review-question-translation">
          {{ currentQuestion.helper_text }}
        </view>
        <view wx:if="{{currentQuestion.helper_role === 'hint' && currentQuestion.helper_text}}" class="review-question-hint">
          {{ currentQuestion.helper_text }}
        </view>
      </view>
      <view wx:if="{{answerFeedback}}" id="review-feedback-anchor" class="{{answerFeedback.panelClass}} review-inline-feedback">
        <view class="answer-feedback-head">
          <view class="answer-feedback-badge">{{answerFeedback.isCorrect ? '正确' : '错因'}}</view>
          <view class="answer-feedback-title">{{answerFeedback.title}}</view>
        </view>
        <view class="answer-feedback-text">{{answerFeedback.explanation}}</view>
        <view wx:if="{{!answerFeedback.isCorrect}}" class="answer-feedback-answer">
          正确答案：{{answerFeedback.correctAnswer}}
        </view>
        <view wx:if="{{answerFeedback.revealedWord || answerFeedback.example_sentence || answerFeedback.meaning_cn || answerFeedback.part_of_speech || answerFeedback.usage_tip}}" class="answer-feedback-knowledge">
          <view wx:if="{{answerFeedback.revealedWord && answerFeedback.revealedWord !== currentQuestion.stem}}" class="answer-feedback-word-inline">
            {{answerFeedback.revealedWord}}
          </view>
          <view wx:if="{{answerFeedback.meaning_cn || answerFeedback.part_of_speech}}" class="answer-feedback-meaning-line">
            <view wx:if="{{answerFeedback.meaning_cn}}" class="answer-feedback-meaning-main">{{answerFeedback.meaning_cn}}</view>
            <view wx:if="{{answerFeedback.part_of_speech}}" class="answer-feedback-pos-main">{{answerFeedback.part_of_speech}}</view>
          </view>
          <view wx:if="{{answerFeedback.usage_tip}}" class="answer-feedback-knowledge-line stacked">
            <text class="answer-feedback-knowledge-label">用法提醒</text>
            <text class="answer-feedback-knowledge-value">{{answerFeedback.usage_tip}}</text>
          </view>
          <view wx:if="{{answerFeedback.example_sentence}}" class="answer-feedback-example">
            <view class="answer-feedback-example-head">
              <view class="answer-feedback-knowledge-label">例句</view>
              <button class="ghost-btn answer-feedback-audio-btn" loading="{{feedbackAudioBusy}}" bindtap="playFeedbackExampleAudio">重播例句</button>
            </view>
            <view class="answer-feedback-example-text">{{answerFeedback.example_sentence}}</view>
            <view wx:if="{{answerFeedback.example_translation}}" class="answer-feedback-example-translation">{{answerFeedback.example_translation}}</view>
          </view>
        </view>
        <view class="button-row review-inline-feedback-actions" wx:if="{{!answerFeedback.isCorrect}}">
          <button class="ghost-btn full-btn" bindtap="goAiWrongWords">去 AI 深度复盘</button>
        </view>
      </view>
      <view class="review-status-strip">
        <view class="review-status-pill {{autoPlayAudioEnabled ? 'enabled' : ''}}">{{ autoPlayAudioEnabled ? '自动发音已开' : '自动发音未开' }}</view>
        <view class="review-status-text">{{ autoPlayAudioEnabled ? '切到下一题会自动播放发音。' : '可以在设置中开启切题自动发音。' }}</view>
      </view>
    </view>

    <view wx:if="{{hasQuestion && currentQuestion.answer_mode === 'choice'}}" class="section review-choice-section">
      <view
        wx:for="{{options}}"
        wx:key="key"
        class="{{ item.className }}"
        data-value="{{item.value}}"
        bindtap="chooseOption"
      >
        <view class="choice-item">
          <view class="choice-key">{{ item.key }}</view>
          <view class="list-main">
            <view class="list-title">{{ item.value }}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasQuestion && currentQuestion.answer_mode === 'input'}}" class="section panel-card">
      <view class="card-title">输入答案</view>
      <input class="answer-input" placeholder="请输入单词拼写或答案" value="{{inputValue}}" bindinput="handleInput" />
    </view>

    <view wx:if="{{hasQuestion && (reviewAiTutor || reviewAiLoading || reviewAiError)}}" class="section panel-card review-ai-card">
      <view class="review-ai-head">
        <view>
          <view class="card-title">AI 讲词</view>
          <view class="card-subtitle">复习当前这题时，也可以直接打开 AI 讲词，不用跳到别的页面。</view>
        </view>
        <view class="review-ai-badge {{reviewAiTutor ? 'enabled' : ''}}">{{ reviewAiTutor ? 'AI 已生成' : '生成中' }}</view>
      </view>

      <view class="button-row review-ai-actions">
        <button class="secondary-btn review-ai-btn" loading="{{reviewAiLoading}}" bindtap="handleReviewAiTutor">
          {{ reviewAiTutor ? 'AI 重讲这题' : '开启 AI 讲词' }}
        </button>
        <button wx:if="{{reviewAiTutor}}" class="ghost-btn review-ai-btn" bindtap="handleClearReviewAiTutor">收起 AI 讲词</button>
      </view>

      <view wx:if="{{reviewAiLoading}}" class="review-ai-loading">AI 正在结合当前题目的单词、例句和你的复习上下文生成讲解...</view>
      <view wx:elif="{{reviewAiError}}" class="review-ai-error">{{ reviewAiError }}</view>

      <view wx:if="{{reviewAiTutor}}" class="review-ai-body">
        <view class="review-ai-highlight">
          <view class="review-ai-title">AI 一句话讲清</view>
          <view class="review-ai-text">{{ reviewAiTutor.simple_explanation_cn }}</view>
        </view>
        <view class="review-ai-grid">
          <view class="review-ai-note-card">
            <view class="review-ai-title">记忆提示</view>
            <view class="review-ai-text">{{ reviewAiTutor.memory_tip }}</view>
          </view>
          <view class="review-ai-note-card">
            <view class="review-ai-title">使用提醒</view>
            <view class="review-ai-text">{{ reviewAiTutor.usage_tip }}</view>
          </view>
        </view>
        <view wx:if="{{reviewAiTutor.why_recommended}}" class="review-ai-why">
          <view class="review-ai-title">为什么现在讲它</view>
          <view class="review-ai-text">{{ reviewAiTutor.why_recommended }}</view>
        </view>
        <view wx:if="{{reviewAiTutor.mini_quiz}}" class="review-ai-quiz">
          <view class="review-ai-title">AI 微练习</view>
          <view class="review-ai-text">{{ reviewAiTutor.mini_quiz.prompt }}</view>
          <view wx:for="{{reviewAiTutor.mini_quiz.options}}" wx:key="index" class="review-ai-option">{{ index + 1 }}. {{ item }}</view>
          <button class="secondary-btn full-btn" bindtap="toggleReviewAiAnswer">
            {{ reviewAiAnswerVisible ? '收起答案' : '查看答案' }}
          </button>
          <view wx:if="{{reviewAiAnswerVisible}}" class="review-ai-answer">
            <view class="review-ai-title">答案</view>
            <view class="review-ai-text">{{ reviewAiTutor.mini_quiz.answer }}</view>
            <view class="review-ai-answer-tip">{{ reviewAiTutor.mini_quiz.explanation }}</view>
          </view>
        </view>
        <ai-evidence wx:if="{{reviewAiEvidence}}" evidence="{{reviewAiEvidence}}" title="AI 讲词证据区" />
      </view>
    </view>

    <view wx:if="{{!hasQuestion}}" class="section panel-card">
      <empty-state text="当前没有待复习题目" hint="先去学习一些新词，系统就会帮你安排复习。" />
    </view>

    <view wx:if="{{hasQuestion}}" class="review-bottom-spacer"></view>
  </scroll-view>

  <view wx:if="{{hasQuestion}}" class="review-bottom-bar">
    <view class="review-bottom-card">
      <view class="button-row review-bottom-actions">
        <button
          wx:if="{{currentQuestion.speech_text}}"
          class="ghost-btn review-bottom-mini-btn"
          loading="{{audioBusy}}"
          bindtap="playListeningAudio"
        >
          重播
        </button>
        <button
          class="ghost-btn review-bottom-mini-btn"
          loading="{{reviewAiLoading}}"
          disabled="{{!currentQuestion.word_id}}"
          bindtap="handleReviewAiTutor"
        >
          {{ reviewAiTutor ? 'AI重讲' : 'AI讲词' }}
        </button>
        <button class="primary-btn review-bottom-submit-btn {{submitDisabled ? 'is-disabled' : ''}}" loading="{{submitting}}" disabled="{{submitDisabled}}" bindtap="submitAnswer">
          {{submitButtonText}}
        </button>
      </view>
    </view>
  </view>
</view>

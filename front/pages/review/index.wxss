@import "../../styles/theme.wxss";

.review-page .page-scroll {
  padding-bottom: 332rpx;
}

.review-choice-section {
  margin-bottom: 8rpx;
}

.review-choice-section .option-card {
  margin-bottom: 18rpx;
}

.review-choice-section .option-card:last-child {
  margin-bottom: 0;
}

.review-bottom-spacer {
  width: 100%;
  height: calc(188rpx + env(safe-area-inset-bottom));
}

.adaptive-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-a), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--theme-page-end) 100%);
}

.adaptive-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.adaptive-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.adaptive-tip {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.question-reason {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.review-question-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-a), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, var(--theme-page-end) 100%);
}

.review-question-panel {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(44, 93, 255, 0.08);
}

.review-question-prompt {
  color: var(--theme-secondary-text);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.review-question-main {
  display: flex;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 12rpx;
}

.review-question-stem {
  color: var(--theme-text-primary);
  word-break: break-word;
}

.review-question-stem--word {
  font-size: 62rpx;
  line-height: 1.08;
  font-weight: 800;
}

.review-question-stem--meaning {
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 800;
}

.review-question-stem--sentence {
  font-size: 32rpx;
  line-height: 1.7;
  font-weight: 700;
}

.review-question-stem--listening {
  font-size: 32rpx;
  line-height: 1.55;
  font-weight: 700;
}

.review-question-pos-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.1);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.review-question-translation,
.review-question-hint {
  margin-top: 14rpx;
  color: var(--theme-text-secondary);
  line-height: 1.7;
}

.review-question-translation {
  font-size: 28rpx;
}

.review-question-hint {
  font-size: 24rpx;
}

.review-status-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(44, 93, 255, 0.08);
}

.review-status-pill,
.review-bottom-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  color: var(--theme-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.review-status-pill.enabled,
.review-bottom-badge.enabled {
  background: rgba(44, 93, 255, 0.1);
  color: var(--theme-secondary-text);
}

.review-status-text {
  min-width: 0;
  flex: 1;
  color: var(--theme-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.review-ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title.small {
  font-size: 30rpx;
}

.review-ai-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-b), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--theme-page-end) 100%);
}

.review-ai-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  color: var(--theme-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.review-ai-badge.enabled {
  background: rgba(44, 93, 255, 0.1);
  color: var(--theme-secondary-text);
}

.review-ai-actions {
  margin-top: 18rpx;
  gap: 14rpx;
  flex-wrap: wrap;
}

.review-ai-btn {
  flex: 1;
  min-width: 200rpx;
}

.review-ai-loading,
.review-ai-error {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.review-ai-loading {
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
}

.review-ai-error {
  background: rgba(183, 28, 28, 0.08);
  color: #b91c1c;
}

.review-ai-body {
  margin-top: 18rpx;
}

.review-ai-highlight {
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(44, 93, 255, 0.08) 0%, rgba(120, 156, 255, 0.12) 100%);
}

.review-ai-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-secondary-text);
}

.review-ai-text,
.review-ai-answer-tip {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--theme-text-primary);
  word-break: break-word;
}

.review-ai-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.review-ai-note-card,
.review-ai-why,
.review-ai-quiz {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid var(--theme-card-border);
  box-shadow: 0 10rpx 24rpx var(--theme-card-shadow);
}

.review-ai-why,
.review-ai-quiz {
  margin-top: 18rpx;
}

.review-ai-option {
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.06);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.review-ai-answer {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(15, 118, 110, 0.08);
}

.choice-active {
  border: 2rpx solid var(--theme-accent);
  background: var(--theme-secondary-bg);
}

.answer-feedback {
  padding: 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid var(--theme-card-border);
  background: #ffffff;
}

.answer-feedback.correct {
  border-color: rgba(22, 163, 74, 0.28);
  background: rgba(22, 163, 74, 0.07);
}

.answer-feedback.wrong {
  border-color: rgba(220, 38, 38, 0.25);
  background: rgba(220, 38, 38, 0.07);
}

.answer-feedback-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.answer-feedback-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
  font-size: 22rpx;
  font-weight: 700;
}

.answer-feedback-title {
  color: var(--theme-text-primary);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.answer-feedback-text,
.answer-feedback-tip,
.answer-feedback-answer {
  margin-top: 14rpx;
  color: var(--theme-text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.answer-feedback-tip {
  color: var(--theme-text-primary);
}

.answer-feedback-answer {
  font-weight: 700;
  color: #b91c1c;
}

.review-inline-feedback {
  margin-top: 20rpx;
}

.answer-feedback-knowledge {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid rgba(44, 93, 255, 0.08);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.answer-feedback-word-inline {
  color: #163b9d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 1rpx;
  word-break: break-word;
}

.answer-feedback-knowledge-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.answer-feedback-knowledge-line.stacked {
  flex-direction: column;
  gap: 8rpx;
}

.answer-feedback-knowledge-label {
  flex-shrink: 0;
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.answer-feedback-knowledge-value {
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.answer-feedback-meaning-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.answer-feedback-meaning-main {
  color: var(--theme-text-primary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.answer-feedback-pos-main {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 700;
}

.answer-feedback-example {
  padding-top: 6rpx;
}

.answer-feedback-example-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.answer-feedback-audio-btn {
  min-height: 60rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.answer-feedback-example-text,
.answer-feedback-example-translation {
  margin-top: 10rpx;
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.8;
}

.answer-feedback-example-translation {
  color: var(--theme-text-secondary);
}

.review-inline-feedback-actions {
  margin-top: 18rpx;
}

.answer-input {
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid var(--theme-card-border);
  background: #fff;
  color: var(--theme-text-primary);
  font-size: var(--theme-font-size-base);
}

ai-evidence {
  display: block;
  margin-top: 18rpx;
}

.review-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 0 20rpx calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  pointer-events: none;
}

.review-bottom-card {
  pointer-events: auto;
  padding: 14rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid rgba(219, 228, 240, 0.92);
  box-shadow: 0 -10rpx 28rpx rgba(30, 64, 175, 0.1);
}

.review-bottom-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.review-bottom-mini-btn {
  flex: 1;
  min-width: 0;
  min-height: 72rpx;
  padding: 0 16rpx;
  font-size: 25rpx;
}

.review-bottom-submit-btn {
  flex: 1.4;
  min-width: 0;
  min-height: 72rpx;
  margin-top: 0;
  font-size: 28rpx;
}

.is-disabled {
  opacity: 0.5;
}

@media (max-width: 560px) {
  .review-ai-grid {
    grid-template-columns: 1fr;
  }

  .review-status-strip {
    flex-direction: column;
    align-items: stretch;
  }

  .answer-feedback-knowledge-line,
  .answer-feedback-example-head {
    flex-direction: column;
    align-items: stretch;
  }

  .review-bottom-bar {
    padding-left: 16rpx;
    padding-right: 16rpx;
  }

  .review-bottom-actions {
    gap: 10rpx;
  }

  .review-bottom-mini-btn,
  .review-bottom-submit-btn {
    min-height: 72rpx;
  }
}

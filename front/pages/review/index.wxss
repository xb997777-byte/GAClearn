@import "../../styles/theme.wxss";

.adaptive-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 248, 255, 0.98) 100%);
}

.adaptive-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.adaptive-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.adaptive-tip {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.question-reason {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-secondary-text);
  font-size: 24rpx;
  font-weight: 700;
}

.listen-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 248, 255, 0.98) 100%);
}

.listen-head,
.review-ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title.small {
  font-size: 30rpx;
}

.listen-play-btn {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0 26rpx;
  line-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.listen-play-btn::after {
  border: 0;
}

.review-ai-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 248, 255, 0.98) 100%);
}

.review-ai-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  color: var(--theme-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.review-ai-badge.enabled {
  background: rgba(44, 93, 255, 0.1);
  color: var(--theme-secondary-text);
}

.review-ai-actions {
  margin-top: 18rpx;
  gap: 14rpx;
  flex-wrap: wrap;
}

.review-ai-btn {
  flex: 1;
  min-width: 200rpx;
}

.review-ai-loading,
.review-ai-error {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.review-ai-loading {
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
}

.review-ai-error {
  background: rgba(183, 28, 28, 0.08);
  color: #b91c1c;
}

.review-ai-body {
  margin-top: 18rpx;
}

.review-ai-highlight {
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(44, 93, 255, 0.08) 0%, rgba(120, 156, 255, 0.12) 100%);
}

.review-ai-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-secondary-text);
}

.review-ai-text,
.review-ai-answer-tip {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--theme-text-primary);
  word-break: break-word;
}

.review-ai-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.review-ai-note-card,
.review-ai-why,
.review-ai-quiz {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid var(--theme-card-border);
  box-shadow: 0 10rpx 24rpx var(--theme-card-shadow);
}

.review-ai-why,
.review-ai-quiz {
  margin-top: 18rpx;
}

.review-ai-option {
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.06);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.review-ai-answer {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(15, 118, 110, 0.08);
}

.choice-active {
  border: 2rpx solid var(--theme-accent);
  background: var(--theme-secondary-bg);
}

.answer-feedback {
  padding: 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid var(--theme-card-border);
  background: #ffffff;
}

.answer-feedback.correct {
  border-color: rgba(22, 163, 74, 0.28);
  background: rgba(22, 163, 74, 0.07);
}

.answer-feedback.wrong {
  border-color: rgba(220, 38, 38, 0.25);
  background: rgba(220, 38, 38, 0.07);
}

.answer-feedback-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.answer-feedback-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
  font-size: 22rpx;
  font-weight: 700;
}

.answer-feedback-title {
  color: var(--theme-text-primary);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.answer-feedback-text,
.answer-feedback-tip,
.answer-feedback-answer {
  margin-top: 14rpx;
  color: var(--theme-text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.answer-feedback-tip {
  color: var(--theme-text-primary);
}

.answer-feedback-answer {
  font-weight: 700;
  color: #b91c1c;
}

.answer-input {
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid var(--theme-card-border);
  background: #fff;
  color: var(--theme-text-primary);
  font-size: var(--theme-font-size-base);
}

ai-evidence {
  display: block;
  margin-top: 18rpx;
}

@media (max-width: 560px) {
  .review-ai-grid {
    grid-template-columns: 1fr;
  }
}

@import "../../styles/theme.wxss";

.ai-card {
  background:
    radial-gradient(circle at top right, var(--theme-page-glow-a), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--theme-page-end) 100%);
}

.ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.ai-switch-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.ai-switch-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-secondary-text);
}

.ai-refresh-btn {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0 26rpx;
  line-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--theme-font-size-button);
  box-sizing: border-box;
}

.ai-refresh-btn::after {
  border: 0;
}

.ai-loading,
.ai-error {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.ai-loading {
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-text-primary);
}

.ai-error {
  background: rgba(183, 28, 28, 0.08);
  color: #b91c1c;
}

.ai-body {
  margin-top: 18rpx;
}

.ai-highlight {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(44, 93, 255, 0.08) 0%, rgba(111, 168, 255, 0.12) 100%);
}

.ai-highlight-label,
.ai-section-title,
.ai-tip-title,
.quiz-answer-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-secondary-text);
}

.ai-highlight-text,
.ai-tip-text,
.ai-bullet-text,
.compare-diff,
.quiz-prompt,
.quiz-answer-text,
.quiz-answer-explain,
.example-sentence,
.example-translation {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--theme-text-primary);
  word-break: break-word;
}

.ai-tip-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.ai-tip-card,
.compare-card,
.ai-quiz-card,
.ai-why-box {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid var(--theme-card-border);
  box-shadow: 0 10rpx 24rpx var(--theme-card-shadow);
}

.ai-why-box,
.ai-list-block,
.ai-quiz-card {
  margin-top: 18rpx;
}

.ai-bullet-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 14rpx;
}

.ai-bullet-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: var(--theme-accent);
  flex-shrink: 0;
}

.compare-card {
  margin-top: 14rpx;
}

.compare-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.compare-word {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--theme-text-primary);
}

.compare-meaning {
  font-size: 24rpx;
  color: var(--theme-text-secondary);
  text-align: right;
}

.quiz-option {
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(44, 93, 255, 0.06);
  color: var(--theme-text-primary);
  font-size: 26rpx;
  line-height: 1.7;
}

.quiz-answer-box {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(15, 118, 110, 0.08);
}

.example-translation {
  margin-top: 8rpx;
  color: var(--theme-text-secondary);
}

ai-evidence {
  display: block;
  margin-top: 18rpx;
}

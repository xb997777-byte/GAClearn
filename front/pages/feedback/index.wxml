<view class="page-shell {{themePageClass}}" style="{{pageThemeStyle}}">
  <nav-bar title="意见反馈" showBack="{{true}}" />
  <scroll-view class="page-scroll" scroll-y>
    <view class="section hero-card">
      <view class="card-title" style="color:#fff;">意见反馈</view>
      <view class="card-subtitle light-text">你遇到的问题、想要的功能或内容纠错都会进入后台处理列表。</view>
    </view>

    <view class="section panel-card">
      <view class="card-title">反馈类型</view>
      <view class="feedback-chip-row">
        <view
          wx:for="{{categoryOptions}}"
          wx:key="value"
          class="{{item.className}}"
          data-value="{{item.value}}"
          bindtap="handleCategorySelect"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="section panel-card">
      <view class="card-title">反馈内容</view>
      <textarea
        class="feedback-textarea"
        maxlength="2000"
        placeholder="请描述问题、建议或希望优化的地方"
        value="{{content}}"
        bindinput="handleContentInput"
      />
      <view class="feedback-counter">{{contentLength}} / 2000</view>
    </view>

    <view class="section panel-card">
      <view class="card-title">联系方式</view>
      <view class="card-subtitle">选填。留下微信、邮箱或手机号，方便管理员后续确认细节。</view>
      <input
        class="feedback-input"
        placeholder="选填"
        value="{{contact}}"
        bindinput="handleContactInput"
      />
    </view>

    <view class="section panel-card">
      <button class="primary-btn full-btn" loading="{{submitting}}" bindtap="handleSubmit">提交反馈</button>
    </view>
  </scroll-view>
</view>

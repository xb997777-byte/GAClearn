@import "../../styles/theme.wxss";

.settings-block {
  padding: 22rpx 0;
  border-bottom: 2rpx solid var(--theme-divider);
}

.speed-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.speed-chip {
  min-width: 96rpx;
  min-height: 60rpx;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: 2rpx solid var(--theme-card-border);
  background: #ffffff;
  color: var(--theme-text-secondary);
  font-size: var(--theme-font-size-list-desc);
  font-weight: 700;
  box-sizing: border-box;
}

.speed-chip.active {
  border-color: var(--theme-accent);
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
}

.rag-status-block {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: var(--theme-secondary-bg);
}

.rag-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0;
}

.rag-status-label {
  color: var(--theme-text-secondary);
  font-size: var(--theme-font-size-list-desc);
}

.rag-status-value {
  color: var(--theme-text-primary);
  font-size: var(--theme-font-size-list-desc);
  font-weight: 700;
  text-align: right;
}

.rag-error {
  margin-top: 12rpx;
  color: #d14343;
  font-size: var(--theme-font-size-list-desc);
  line-height: 1.5;
}

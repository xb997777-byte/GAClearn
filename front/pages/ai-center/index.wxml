        <ai-evidence evidence="{{ragResult.evidence}}" title="结构化 RAG 证据区" />
      </view>

      <view class="ai-divider"></view>
      <view class="card-title compact-title">向量 RAG</view>
      <view class="card-subtitle">{{ragViewMode === 'learning' ? '像按意思相近去找资料，适合问法不那么标准的情况。' : '优先使用 Chroma 标准 RAG；如果依赖或索引不可用，再回退到本地轻量 token 向量检索。'}}</view>
      <view class="ai-chip-row wrap">
        <view class="ai-choice {{vectorRagMode === 'auto' ? 'active' : ''}}" data-mode="auto" bindtap="handleVectorRagMode">自动</view>
        <view class="ai-choice {{vectorRagMode === 'hybrid' ? 'active' : ''}}" data-mode="hybrid" bindtap="handleVectorRagMode">混合</view>
        <view class="ai-choice {{vectorRagMode === 'vector_only' ? 'active' : ''}}" data-mode="vector_only" bindtap="handleVectorRagMode">仅向量</view>
        <view class="ai-choice {{vectorRagMode === 'structured_only' ? 'active' : ''}}" data-mode="structured_only" bindtap="handleVectorRagMode">仅结构化</view>
      </view>
      <input class="ai-input" value="{{vectorRagQuery}}" bindinput="handleVectorRagQuery" />
      <button class="secondary-btn full-btn ai-action" loading="{{vectorRagLoading}}" disabled="{{vectorRagLoading}}" bindtap="searchVectorRag">{{ragViewMode === 'learning' ? '按相近意思查' : '运行向量 RAG'}}</button>
      <view wx:if="{{vectorRagResult}}" class="ai-result-block">
        <view class="ai-result-title">{{vectorRagResult.answer.summary}}</view>
        <view wx:for="{{vectorRagResult.answer.grounded_points}}" wx:key="index" class="ai-bullet">{{item}}</view>
        <view class="ai-card-row">
          <view class="ai-card-title">{{ragViewMode === 'learning' ? '当前向量能力状态' : '向量运行时说明'}}</view>
          <view class="ai-card-text">{{ragViewMode === 'learning' ? (vectorRagResult.retrieval_strategy.external_vector_db ? '当前优先走 Chroma 标准 RAG，从项目知识库里按语义相似度召回知识块。' : '当前由于依赖或索引未就绪，临时回退到了项目内的本地轻量相似度检索。') : (vectorRagResult.retrieval_strategy.external_vector_db ? '当前已接入 Chroma，external_vector_db 为 true。' : '当前未走 Chroma 主路径，正在使用本地轻量回退链路。')}}</view>
        </view>
        <view wx:if="{{vectorRagResult.retrieval_strategy}}" class="ai-card-row">
          <view class="ai-card-title">向量运行时</view>
          <view class="ai-card-text">{{vectorRagResult.retrieval_strategy.type}} / {{vectorRagResult.retrieval_strategy.version}}</view>
          <view class="ai-card-tip">{{vectorRagResult.retrieval_strategy.backend}} · 模式：{{vectorRagResult.retrieval_strategy.retrieval_mode || vectorRagMode}}</view>
        </view>
        <view wx:if="{{vectorRagResult.retrieval_explain}}" class="ai-card-row">

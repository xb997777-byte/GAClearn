      <input class="ai-input" value="{{ragQuery}}" bindinput="handleRagQuery" />
      <button class="secondary-btn full-btn ai-action" loading="{{ragSearchLoading}}" disabled="{{ragSearchLoading}}" bindtap="searchRag">{{ragViewMode === 'learning' ? '查资料回答' : '运行结构化 RAG'}}</button>
      <view wx:if="{{ragResult}}" class="ai-result-block">
        <view class="ai-result-title">{{ragResult.answer.summary}}</view>

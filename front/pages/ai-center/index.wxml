<view class="page-shell {{themePageClass}}" style="{{pageThemeStyle}}">
  <nav-bar title="AI 中心" />
  <scroll-view class="page-scroll" scroll-y>
    <view class="section hero-card">
      <view class="ai-collapsible-head" bindtap="toggleCapabilityIntro">
        <view>
          <view class="card-title" style="color:#fff;">AI 工作台说明</view>
          <view class="card-subtitle light-text">默认收起，避免技术说明挡住直接使用入口。</view>
        </view>
        <view class="ai-collapse-indicator light">{{capabilityIntroCollapsed ? '展开' : '收起'}}</view>
      </view>
      <block wx:if="{{!capabilityIntroCollapsed}}">
        <view class="card-subtitle light-text">
          这里保留了项目的 AI 能力说明，但默认体验优先面向学习者：先提问、先拿结果，技术细节按需展开。
        </view>
        <view class="tag-row ai-runtime-row" wx:if="{{capabilities}}">
          <view class="chip">运行时 {{capabilities.preferred_runtime}}</view>
          <view class="chip">模型 {{capabilities.model_name || '未配置'}}</view>
          <view class="chip">{{capabilities.mcp_available ? 'MCP 已就绪' : 'MCP 已降级'}}</view>
          <view class="chip">{{capabilities.mcp_stdio_available ? 'STDIO 已就绪' : '仅 HTTP'}}</view>
          <view class="chip">{{capabilities.worker_healthy ? 'Worker 健康' : 'Worker 异常'}}</view>
          <view class="chip">{{capabilities.auto_recover_enabled ? '自动恢复已开启' : '自动恢复未开启'}}</view>
        </view>
        <view class="ai-tech-grid" wx:if="{{stackShowcase.length}}">
          <view wx:for="{{stackShowcase}}" wx:key="title" class="ai-tech-card">
            <view class="ai-tech-head">
              <view class="ai-tech-title">{{item.title}}</view>
              <view class="ai-tech-badge">{{item.badge}}</view>
            </view>
            <view class="ai-tech-text">{{item.detail}}</view>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{moduleMaturityPanels.length}}" class="section panel-card">
      <view class="ai-collapsible-head" bindtap="toggleModuleMaturity">
        <view>
          <view class="card-title">模块成熟度</view>
          <view class="card-subtitle">需要时再展开，不抢占应用入口。</view>
        </view>
        <view class="ai-collapse-indicator">{{moduleMaturityCollapsed ? '展开' : '收起'}}</view>
      </view>
      <view wx:if="{{!moduleMaturityCollapsed}}" class="ai-maturity-grid">
        <view wx:for="{{moduleMaturityPanels}}" wx:key="key" class="ai-maturity-card">
          <view class="ai-maturity-head">
            <view class="ai-maturity-title">{{item.title}}</view>
            <view class="ai-maturity-badge tone-{{item.tone}}">{{item.status}}</view>
          </view>
          <view class="ai-maturity-text">{{item.detail}}</view>
          <view class="ai-maturity-note">{{item.note}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{capabilities}}" class="section panel-card">
      <view class="ai-collapsible-head" bindtap="toggleCapabilityIntro">
        <view>
          <view class="card-title">Runtime 健康详情</view>
          <view class="card-subtitle">Redis、Worker、队列与失活任务恢复状态。</view>
        </view>
        <view class="ai-collapse-indicator">{{capabilityIntroCollapsed ? '展开' : '收起'}}</view>
      </view>
      <block wx:if="{{!capabilityIntroCollapsed}}">
        <view class="ai-grid-two">
          <view class="ai-metric-card">
            <view class="ai-metric-label">Worker 状态</view>
            <view class="ai-metric-value small">{{capabilities.worker_healthy ? '健康' : '异常'}}</view>
          </view>
          <view class="ai-metric-card">
            <view class="ai-metric-label">Redis</view>
            <view class="ai-metric-value small">{{capabilities.redis_reachable ? '可达' : '不可达'}}</view>
          </view>
          <view class="ai-metric-card">
            <view class="ai-metric-label">自动恢复</view>
            <view class="ai-metric-value small">{{capabilities.auto_recover_enabled ? '已开启' : '未开启'}}</view>
          </view>
          <view class="ai-metric-card">
            <view class="ai-metric-label">Stale Run</view>
            <view class="ai-metric-value">{{capabilities.stale_run_count || 0}}</view>
          </view>
        </view>
        <view class="ai-card-row">
          <view class="ai-card-title">在线 Worker</view>
          <view class="ai-card-text">{{capabilities.workers && capabilities.workers.length ? capabilities.workers.join('，') : '当前未探测到在线 worker'}}</view>
        </view>
        <view class="ai-card-row">
          <view class="ai-card-title">观测到的队列</view>
          <view class="ai-card-text">{{capabilities.observed_queues && capabilities.observed_queues.length ? capabilities.observed_queues.join('，') : '尚未探测到队列'}}</view>
        </view>
        <view class="ai-card-row">
          <view class="ai-card-title">自动恢复策略</view>
          <view class="ai-card-text">每 {{capabilities.auto_recover_every_seconds || 0}} 秒最多恢复 {{capabilities.auto_recover_limit || 0}} 个失活任务</view>
          <view wx:if="{{capabilities.degraded_reason}}" class="ai-card-tip">{{capabilities.degraded_reason}}</view>
        </view>
        <view wx:if="{{capabilities.stale_runs_preview && capabilities.stale_runs_preview.length}}" class="ai-card-row">
          <view class="ai-card-title">待恢复任务预览</view>
          <view wx:for="{{capabilities.stale_runs_preview}}" wx:key="run_id" class="ai-bullet">{{item.feature_type}} · {{item.run_id}} · {{item.status}} · {{item.queue_name}}</view>
        </view>
      </block>
    </view>

    <view class="section panel-card">
      <view class="ai-tab-row">
        <view class="ai-tab {{activeTab === 'apps' ? 'active' : ''}}" data-tab="apps" bindtap="switchTab">应用</view>
        <view class="ai-tab {{activeTab === 'agent' ? 'active' : ''}}" data-tab="agent" bindtap="switchTab">改计划</view>
        <view class="ai-tab {{activeTab === 'rag' ? 'active' : ''}}" data-tab="rag" bindtap="switchTab">问资料</view>
        <view class="ai-tab {{activeTab === 'mcp' ? 'active' : ''}}" data-tab="mcp" bindtap="switchTab">技能</view>
        <view class="ai-tab {{activeTab === 'ops' ? 'active' : ''}}" data-tab="ops" bindtap="switchTab">观测</view>
      </view>
    </view>

      <view wx:if="{{activeTab === 'agent'}}" class="section panel-card">
      <view class="card-title">AI 帮你重排今天学习</view>
      <view class="card-subtitle">
        系统会结合当前计划、今日任务、错词本、到期复习词和近期趋势，给你一份更适合今天状态的学习安排。
      </view>
      <button class="primary-btn full-btn ai-action" loading="{{agentLoading}}" disabled="{{agentLoading}}" bindtap="loadPlanReplanner">生成今天安排</button>
      <view wx:if="{{agentLoading}}" class="ai-loading-tip">{{agentStatusText || 'AI 正在结合你的学习数据整理建议，请稍候...'}}</view>

        <view wx:if="{{planReplanResult}}" class="ai-result-block">
        <view wx:if="{{planReplanResult.runtime_summary && planReplanResult.runtime_summary.summary}}" class="ai-status-banner {{planReplanResult.runtime_summary.degraded ? 'warning' : 'success'}}">
          <view class="ai-status-title">{{planReplanResult.runtime_summary.status_text || '已完成'}}</view>
          <view class="ai-status-text">{{planReplanResult.runtime_summary.summary}}</view>
        </view>
        <view class="ai-agent-plan-card">
          <view class="ai-agent-plan-kicker">AI 给你的今日计划</view>
          <view class="ai-agent-plan-title">{{planReplanResult.planCardTitle}}</view>
          <view class="ai-agent-plan-summary">{{planReplanResult.planCardSummary}}</view>

          <view wx:if="{{planReplanResult.new_plan}}" class="ai-grid-two ai-agent-plan-metrics">
            <view class="ai-metric-card">
              <view class="ai-metric-label">当前日目标</view>
              <view class="ai-metric-value">{{planReplanResult.new_plan.current_daily_target}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">建议日目标</view>
              <view class="ai-metric-value">{{planReplanResult.new_plan.suggested_daily_target}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">建议复习量</view>
              <view class="ai-metric-value">{{planReplanResult.new_plan.review_target}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">推荐模式</view>
              <view class="ai-metric-value small">{{planReplanResult.new_plan.focus_mode_label}}</view>
            </view>
          </view>

          <view wx:if="{{planReplanResult.planStudyOrder.length}}" class="ai-agent-plan-section">
            <view class="ai-section-title">执行顺序</view>
            <view wx:for="{{planReplanResult.planStudyOrder}}" wx:key="index" class="ai-bullet">{{index + 1}}. {{item}}</view>
          </view>

          <view wx:if="{{planReplanResult.planTimeBlocks.length}}" class="ai-agent-plan-section">
            <view class="ai-section-title">建议时间块</view>
            <view wx:for="{{planReplanResult.planTimeBlocks}}" wx:key="index" class="ai-card-row">
              <view class="ai-card-title">{{item.label}} · {{item.minutes}} 分钟</view>
              <view class="ai-card-text">{{item.focus}}</view>
            </view>
          </view>

          <view wx:if="{{planReplanResult.planFocusWords.length}}" class="ai-agent-plan-section">
            <view class="ai-section-title">优先关注词</view>
            <view class="ai-chip-row wrap">
              <view wx:for="{{planReplanResult.planFocusWords}}" wx:key="index" class="ai-choice active">{{item}}</view>
            </view>
          </view>

          <view class="button-row" wx:if="{{currentPlan && planReplanResult.plan_patch && planReplanResult.plan_patch.daily_target}}">
            <button class="secondary-btn full-btn" loading="{{planApplying}}" bindtap="applyReplannedPlan">应用这个计划</button>
          </view>
        </view>

        <view wx:if="{{planReplanResult.decisionReasons.length}}" class="ai-card-row">
          <view class="ai-card-title">为什么这样安排</view>
          <view wx:for="{{planReplanResult.decisionReasons}}" wx:key="index" class="ai-bullet">{{item}}</view>
        </view>

        <view wx:if="{{planReplanResult.expectedBenefit}}" class="ai-card-row">
          <view class="ai-card-title">预期收益</view>
          <view class="ai-card-text">{{planReplanResult.expectedBenefit}}</view>
        </view>

          <view wx:if="{{planReplanResult.decisionRisks.length}}" class="ai-card-row">
            <view class="ai-card-title">提醒</view>
            <view wx:for="{{planReplanResult.decisionRisks}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>

          <view class="ai-result-block ai-collapsible-card">
            <view class="ai-collapsible-head" bindtap="toggleAgentProcess">
              <view>
                <view class="ai-result-title">查看 AI 安排依据</view>
                <view class="ai-card-tip">角色分工、运行轨迹和证据链都收纳在这里。</view>
              </view>
              <view class="ai-collapse-indicator">{{agentProcessCollapsed ? '展开' : '收起'}}</view>
            </view>

            <block wx:if="{{!agentProcessCollapsed}}">
              <view wx:if="{{planReplanResult.multi_agent.roles && planReplanResult.multi_agent.roles.length}}" class="ai-card-row">
                <view class="ai-card-title">多 Agent 角色</view>
                <view wx:for="{{planReplanResult.multi_agent.roles}}" wx:key="name" class="ai-card-row inner-role">
                  <view class="ai-card-title">{{item.title}}</view>
                  <view class="ai-card-text">{{item.responsibility}}</view>
                  <view class="ai-card-tip">输出：{{item.output}}</view>
                </view>
              </view>

              <view wx:if="{{planReplanResult.multi_agent.handoffs && planReplanResult.multi_agent.handoffs.length}}" class="ai-card-row">
                <view class="ai-card-title">角色交接流程</view>
                <view wx:for="{{planReplanResult.multi_agent.handoffs}}" wx:key="index" class="ai-bullet">{{item.from}} → {{item.to}}：{{item.reason}}</view>
              </view>

              <view wx:if="{{planReplanResult.langchain_trace && planReplanResult.langchain_trace.length}}" class="ai-card-row">
                <view class="ai-card-title">LangChain 轨迹</view>
                <view wx:for="{{planReplanResult.langchain_trace}}" wx:key="index" class="ai-log-line">{{item.line}}</view>
              </view>

              <ai-evidence evidence="{{planReplanResult.evidence}}" title="Agent 证据链" />
            </block>
          </view>
        </view>

      <view wx:if="{{profileMemory}}" class="ai-result-block">
        <view class="ai-result-title">AI 长期记忆画像</view>
        <view class="ai-result-text">{{profileMemory.profile_summary}}</view>
        <view class="ai-chip-row wrap">
          <view wx:for="{{profileMemory.preferred_modes}}" wx:key="index" class="ai-choice active">{{item}}</view>
        </view>
        <view wx:if="{{profileMemory.recent_focus_words && profileMemory.recent_focus_words.length}}">
          <view class="ai-section-title">近期重点词</view>
          <view wx:for="{{profileMemory.recent_focus_words}}" wx:key="index" class="ai-bullet">{{item}}</view>
        </view>
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{profileRefreshing}}" disabled="{{profileRefreshing}}" bindtap="refreshProfileMemory">刷新画像</button>
      </view>

      <view wx:if="{{planReplanResult}}" class="ai-result-block">
        <view class="ai-result-title">今日计划详细分析</view>
        <view class="ai-result-text">这份结果和“本日计划”页生成的是同一份 AI 计划，只是这里展示更完整的分析、证据和执行建议。</view>
        <view wx:if="{{currentPlan && planReplanResult.plan_patch && planReplanResult.plan_patch.daily_target}}" class="ai-card-tip">如果你已经看懂原因，可以回到计划页直接应用。</view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'rag'}}" class="section panel-card">
      <view class="card-title">AI 资料问答</view>
      <view class="card-subtitle">像聊天一样直接提问。系统默认用 hybrid RAG 回答，来源与技术细节按需展开，不打断主体验。</view>

      <view class="ai-result-block ai-rag-chat-card">
        <view class="ai-rag-chat-shell">
          <view wx:if="{{!ragChatHistory.length}}" class="ai-rag-empty">
            <view class="ai-rag-empty-title">直接输入问题就可以开始</view>
            <view class="ai-rag-empty-text">例如：important 和 significant 怎么区分？</view>
          </view>

          <block wx:for="{{ragChatHistory}}" wx:key="index">
            <view class="ai-chat-bubble {{item.role === 'user' ? 'user' : 'assistant'}}">
              <view class="ai-chat-role">{{item.role === 'user' ? '你' : 'AI'}}</view>
              <view class="ai-chat-content">{{item.content}}</view>
            </view>
          </block>
        </view>

        <input class="ai-input" value="{{vectorRagQuery}}" bindinput="handleVectorRagQuery" placeholder="比如：important 和 significant 怎么区分？" />
        <button class="primary-btn full-btn ai-action" loading="{{vectorRagLoading}}" disabled="{{vectorRagLoading}}" bindtap="searchVectorRag">发送问题</button>

        <view wx:if="{{vectorRagResult}}" class="ai-result-block inner">
          <view wx:if="{{vectorRagResult.runtime_summary && vectorRagResult.runtime_summary.summary}}" class="ai-status-banner {{vectorRagResult.runtime_summary.degraded ? 'warning' : 'success'}}">
            <view class="ai-status-title">{{vectorRagResult.runtime_summary.status_text || '已完成'}}</view>
            <view class="ai-status-text">{{vectorRagResult.runtime_summary.summary}}</view>
          </view>
          <view class="ai-result-title">{{vectorRagResult.answer_brief.summary}}</view>
          <view wx:for="{{vectorRagResult.answer_brief.points}}" wx:key="index" class="ai-bullet">{{item}}</view>

          <view wx:if="{{ragSourcePills.length}}" class="ai-section-title">本次参考来源</view>
          <view wx:if="{{ragSourcePills.length}}" class="ai-chip-row wrap">
            <view wx:for="{{ragSourcePills}}" wx:key="index" class="ai-choice active">{{item.label}}</view>
          </view>

          <view wx:if="{{vectorRagResult.answer_brief.next_questions.length}}" class="ai-card-row">
            <view class="ai-card-title">你还可以继续问</view>
            <view wx:for="{{vectorRagResult.answer_brief.next_questions}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
        </view>

        <view wx:if="{{activeRunDetail && vectorRagResult && activeRunDetail.run_id === vectorRagResult.run_id}}" class="ai-result-block inner ai-runtime-row">
          <view class="ai-collapsible-head" bindtap="toggleAiRuntimeCollapsed">
            <view>
              <view class="ai-result-title">运行态</view>
              <view class="ai-card-tip">{{activeRunDetail.runtime_summary.status_text || activeRunDetail.status_text || '进行中'}}</view>
            </view>
            <view class="ai-collapse-indicator">{{aiRuntimeCollapsed ? '展开' : '收起'}}</view>
          </view>
          <view class="ai-grid-two">
            <view class="ai-metric-card">
              <view class="ai-metric-label">当前智能体</view>
              <view class="ai-metric-value small">{{activeRunDetail.current_agent || activeRunDetail.runtime_summary.active_agent || '--'}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">步骤数</view>
              <view class="ai-metric-value">{{activeRunDetail.runtime_summary.step_count || activeRunSteps.length || 0}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">审批状态</view>
              <view class="ai-metric-value small">{{activeRunDetail.approval_state || 'not_required'}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">运行状态</view>
              <view class="ai-metric-value small">{{activeRunDetail.runtime_summary.status_text || activeRunDetail.status || '--'}}</view>
            </view>
          </view>
          <view class="button-row">
            <button class="ghost-btn" size="mini" data-action="refresh" bindtap="handleAiRuntimeAction">刷新</button>
            <button class="ghost-btn" size="mini" data-action="retry" bindtap="handleAiRuntimeAction">重试</button>
            <button class="ghost-btn" size="mini" data-action="resume" bindtap="handleAiRuntimeAction">恢复</button>
            <button class="ghost-btn" size="mini" data-action="cancel" bindtap="handleAiRuntimeAction">取消</button>
            <button wx:if="{{activeRunDetail.approval_state === 'pending'}}" class="secondary-btn" size="mini" data-action="approve" bindtap="handleAiRuntimeAction">批准</button>
            <button wx:if="{{activeRunDetail.approval_state === 'pending'}}" class="ghost-btn" size="mini" data-action="reject" bindtap="handleAiRuntimeAction">拒绝</button>
          </view>
          <block wx:if="{{!aiRuntimeCollapsed}}">
            <view wx:if="{{activeRunDetail.runtime_summary.summary}}" class="ai-card-row">
              <view class="ai-card-title">运行摘要</view>
              <view class="ai-card-text">{{activeRunDetail.runtime_summary.summary}}</view>
            </view>
            <view wx:if="{{activeRunSteps.length}}" class="ai-card-row">
              <view class="ai-card-title">步骤时间线</view>
              <view wx:for="{{activeRunSteps}}" wx:key="id" class="ai-card-row app-inner-card">
                <view class="ai-card-tip">#{{item.step_index}} {{item.title}}</view>
                <view class="ai-card-tip">{{item.agent_name || item.step_kind}} · {{item.status}} · {{item.latency_ms || 0}}ms</view>
                <view wx:if="{{item.summary}}" class="ai-card-text">{{item.summary}}</view>
              </view>
            </view>
            <view wx:if="{{activeRunArtifacts.length}}" class="ai-card-row">
              <view class="ai-card-title">运行产物</view>
              <view wx:for="{{activeRunArtifacts}}" wx:key="id" class="ai-card-row app-inner-card">
                <view class="ai-card-tip">{{item.title}}</view>
                <view class="ai-card-tip">{{item.artifact_type}}</view>
                <view wx:if="{{item.summary}}" class="ai-card-text">{{item.summary}}</view>
              </view>
            </view>
          </block>
        </view>
      </view>

      <view wx:if="{{vectorRagResult}}" class="ai-result-block ai-collapsible-card">
        <view class="ai-collapsible-head" bindtap="toggleRagProcess">
          <view>
            <view class="ai-result-title">查看依据</view>
            <view class="ai-card-tip">来源片段、命中原因、证据链、运行时与索引状态都在这里。</view>
          </view>
          <view class="ai-collapse-indicator">{{ragProcessCollapsed ? '展开' : '收起'}}</view>
        </view>

        <block wx:if="{{!ragProcessCollapsed}}">
          <view wx:if="{{vectorRagResult.retrieval_explain}}" class="ai-card-row">
            <view class="ai-card-title">本次检索路径</view>
            <view class="ai-card-text">{{vectorRagResult.retrieval_explain.query_intent.label || '学习问题'}} · {{vectorRagResult.retrieval_strategy.backend}} · 模式：{{vectorRagResult.retrieval_strategy.retrieval_mode || 'hybrid'}}</view>
            <view class="ai-card-tip">{{vectorRagResult.retrieval_explain.query_intent.reason || ''}}</view>
          </view>

          <view wx:if="{{vectorRagResult.retrieval_explain && vectorRagResult.retrieval_explain.personalized_enabled}}" class="ai-card-row">
            <view class="ai-card-title">个性知识库命中</view>
            <view class="ai-card-text">{{vectorRagResult.retrieval_explain.personalized_hits || 0}} 条</view>
            <view class="ai-card-tip">这些命中来自你的学习计划、错词本、最近行为和语法薄弱点摘要。</view>
          </view>

          <view wx:if="{{vectorDocPreview.length}}">
            <view class="ai-section-title">命中详情预览</view>
            <view wx:for="{{vectorDocPreview}}" wx:key="index" class="ai-card-row">
              <view class="ai-card-title">{{item.title}}</view>
              <view class="ai-card-tip">{{item.source_type}} · 相关度 {{item.score}}{{item.rerank_score ? ' · 重排 ' + item.rerank_score : ''}}</view>
              <view wx:if="{{item.source_scope === 'personalized'}}" class="ai-card-tip">来源：你的个性知识库</view>
              <view wx:if="{{item.retrieval_sources.length}}" class="ai-card-tip">来源链路：{{item.retrieval_sources_text}}</view>
              <view wx:if="{{item.match_reason}}" class="ai-card-text">{{item.match_reason}}</view>
              <view wx:if="{{item.matched_keywords.length}}" class="ai-card-tip">命中关键词：{{item.matched_keywords_text}}</view>
              <view wx:for="{{item.highlights}}" wx:key="subIndex" class="ai-log-line">{{item}}</view>
            </view>
          </view>

          <ai-evidence evidence="{{vectorRagResult.evidence}}" title="RAG 证据链" />

          <view wx:if="{{ragRuntime}}" class="ai-card-row">
            <view class="ai-card-title">运行时摘要</view>
            <view class="ai-card-text">{{ragRuntime.backend || '未启用'}} · {{ragRuntime.collection_health || 'unknown'}} · 当前 {{ragRuntime.chunk_count}} / 预计 {{ragRuntime.expected_chunk_count}}</view>
            <view class="ai-card-tip">collection：{{ragRuntime.collection_fingerprint || '--'}} · 维度：{{ragRuntime.embedding_dimension || 0}}</view>
          </view>

          <view wx:if="{{ragIndexStatus}}" class="ai-card-row">
            <view class="ai-card-title">索引状态</view>
            <view class="ai-card-text">{{ragIndexStatus.stateLabel}} · {{ragIndexStatus.progressText}}</view>
            <view class="ai-card-tip">健康度：{{ragIndexStatus.collection_health || 'unknown'}}{{ragIndexStatus.stale_collections.length ? ' · 旧 collection ' + ragIndexStatus.stale_collections.length + ' 个' : ''}}</view>
          </view>
        </block>
      </view>

      <view class="ai-result-block ai-collapsible-card">
        <view class="ai-collapsible-head" bindtap="toggleRagAdvanced">
          <view>
            <view class="ai-result-title">高级模式</view>
            <view class="ai-card-tip">保留结构化 RAG、索引状态和召回评测，方便你继续查看详细过程。</view>
          </view>
          <view class="ai-collapse-indicator">{{ragAdvancedCollapsed ? '展开' : '收起'}}</view>
        </view>

        <block wx:if="{{!ragAdvancedCollapsed}}">
          <view wx:if="{{ragRuntime}}" class="ai-result-block inner">
            <view class="ai-result-title">标准 RAG 运行状态</view>
            <view class="ai-grid-two">
              <view class="ai-metric-card">
                <view class="ai-metric-label">向量引擎</view>
                <view class="ai-metric-value small">{{ragRuntime.backend || '未启用'}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">索引状态</view>
                <view class="ai-metric-value">{{ragRuntime.indexed ? '已构建' : '未构建'}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">知识块数量</view>
                <view class="ai-metric-value">{{ragRuntime.chunk_count}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">预期总块数</view>
                <view class="ai-metric-value">{{ragRuntime.expected_chunk_count}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">Collection 指纹</view>
                <view class="ai-metric-value small">{{ragRuntime.collection_fingerprint || '--'}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">Embedding 维度</view>
                <view class="ai-metric-value">{{ragRuntime.embedding_dimension || 0}}</view>
              </view>
            </view>
            <view wx:if="{{ragRuntime.source_breakdown.length}}">
              <view class="ai-section-title">知识源分布</view>
              <view wx:for="{{ragRuntime.source_breakdown}}" wx:key="key" class="ai-card-row">
                <view class="ai-card-title">{{item.label}}</view>
                <view class="ai-card-text">记录数 {{item.record_count}} · 预计块数 {{item.chunk_count}}</view>
              </view>
            </view>
            <view wx:if="{{ragRuntime.knowledge_source_catalog && ragRuntime.knowledge_source_catalog.length}}">
              <view class="ai-section-title">当前知识源目录</view>
              <view wx:for="{{ragRuntime.knowledge_source_catalog}}" wx:key="key" class="ai-card-row">
                <view class="ai-card-title">{{item.label}}（{{item.table}}）</view>
                <view class="ai-card-text">{{item.description}}</view>
                <view class="ai-card-tip">当前记录数：{{item.record_count}}{{item.chunk_count ? ' · 预计块数：' + item.chunk_count : ''}}</view>
              </view>
            </view>
            <view wx:if="{{ragRuntime.embedding_model}}" class="ai-card-row">
              <view class="ai-card-title">Embedding 模型</view>
              <view class="ai-card-text">{{ragRuntime.embedding_model}}</view>
              <view class="ai-card-tip">后端：{{ragRuntime.embedding_backend || 'unknown'}}{{ragRuntime.embedding_provider ? ' / 提供方：' + ragRuntime.embedding_provider : ''}} · 重建命令：{{ragRuntime.rebuild_command}}</view>
            </view>
          </view>

          <view wx:if="{{ragIndexStatus}}" class="ai-result-block inner">
            <view class="ai-result-title">RAG 索引构建进度</view>
            <view class="ai-grid-two">
              <view class="ai-metric-card">
                <view class="ai-metric-label">当前状态</view>
                <view class="ai-metric-value">{{ragIndexStatus.stateLabel}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">进度</view>
                <view class="ai-metric-value">{{ragIndexStatus.progress_percent}}%</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">已写入</view>
                <view class="ai-metric-value">{{ragIndexStatus.inserted_count}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">预计总量</view>
                <view class="ai-metric-value">{{ragIndexStatus.total_count || ragIndexStatus.expected_chunk_count}}</view>
              </view>
            </view>
            <view class="ai-progress-track" wx:if="{{ragIndexStatus.hasProgress}}">
              <view class="ai-progress-fill" style="{{ragIndexStatus.progressWidth}}"></view>
            </view>
            <view class="ai-card-tip">{{ragIndexStatus.progressText}}</view>
            <view class="ai-card-text">{{ragIndexStatus.actionHint}}</view>
            <view class="button-row">
              <button class="secondary-btn full-btn ai-inline-btn" loading="{{ragIndexLoading}}" disabled="{{ragIndexLoading}}" bindtap="refreshRagIndexStatus">刷新索引状态</button>
            </view>
            <view class="button-row">
              <button class="secondary-btn full-btn ai-inline-btn" loading="{{ragSyncLoading}}" disabled="{{ragSyncLoading}}" bindtap="syncRagIndexIncrementally">增量同步索引</button>
            </view>
            <view wx:if="{{ragIndexStatus.latest_line}}" class="ai-card-row">
              <view class="ai-card-title">最新日志</view>
              <view class="ai-card-text">{{ragIndexStatus.latest_line}}</view>
            </view>
            <view wx:if="{{ragIndexStatus.last_error_line}}" class="ai-card-row">
              <view class="ai-card-title">最近错误</view>
              <view class="ai-card-text">{{ragIndexStatus.last_error_line}}</view>
            </view>
          </view>

          <view class="ai-divider"></view>
          <view class="card-title compact-title">结构化 RAG 调试</view>
          <view class="card-subtitle">保留给你做技术对比和内部调试，不作为默认用户入口。</view>
          <input class="ai-input" value="{{ragQuery}}" bindinput="handleRagQuery" />
          <button class="secondary-btn full-btn ai-action" loading="{{ragSearchLoading}}" disabled="{{ragSearchLoading}}" bindtap="searchRag">运行结构化 RAG</button>
          <view wx:if="{{ragResult}}" class="ai-result-block inner">
            <view class="ai-result-title">{{ragResult.answer.summary}}</view>
            <view wx:for="{{ragResult.answer.grounded_points}}" wx:key="index" class="ai-bullet">{{item}}</view>
            <ai-evidence evidence="{{ragResult.evidence}}" title="结构化 RAG 证据区" />
          </view>

          <view class="ai-divider"></view>
          <view class="card-title compact-title">RAG 召回评测</view>
          <view class="card-subtitle">用于比较 structured / vector / hybrid 的覆盖情况。</view>
          <textarea class="ai-textarea compact" value="{{ragRecallKeywords}}" bindinput="handleRagRecallKeywords" maxlength="200" />
          <view class="ai-chip-row wrap">
            <view class="ai-choice {{ragRecallPreferredSourceType === 'word' ? 'active' : ''}}" data-source-type="word" bindtap="handleRagRecallSourceType">词汇</view>
            <view class="ai-choice {{ragRecallPreferredSourceType === 'grammar_point' ? 'active' : ''}}" data-source-type="grammar_point" bindtap="handleRagRecallSourceType">语法点</view>
            <view class="ai-choice {{ragRecallPreferredSourceType === 'grammar_sentence' ? 'active' : ''}}" data-source-type="grammar_sentence" bindtap="handleRagRecallSourceType">句子</view>
          </view>
          <button class="secondary-btn full-btn ai-action" loading="{{ragRecallLoading}}" disabled="{{ragRecallLoading}}" bindtap="evaluateRagRecall">评测召回</button>
          <view wx:if="{{ragRecallResult}}" class="ai-result-block inner">
            <view class="ai-result-title">{{ragRecallResult.diagnosis}}</view>
            <view class="ai-card-row">
              <view class="ai-card-title">建议策略</view>
              <view class="ai-card-text">{{ragRecallResult.better_strategy}}</view>
            </view>
            <view class="ai-card-row">
              <view class="ai-card-title">结构化覆盖</view>
              <view class="ai-card-text">{{ragRecallResult.structured_recall.coverage_rate}}%</view>
            </view>
            <view class="ai-card-row">
              <view class="ai-card-title">向量覆盖</view>
              <view class="ai-card-text">{{ragRecallResult.vector_recall.coverage_rate}}%</view>
            </view>
            <ai-evidence evidence="{{ragRecallResult.evidence}}" title="RAG 评测证据区" />
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{activeTab === 'mcp'}}" class="section panel-card">
      <view class="card-title">MCP 技能中心</view>
      <view class="card-subtitle">这里默认按技能卡片来用，不需要自己拼 JSON。每个技能都有一句话用途、参数表单和折叠说明。</view>

      <view wx:if="{{mcpManifest}}" class="ai-result-block">
        <view wx:for="{{mcpSkillGroups}}" wx:key="key" wx:for-item="group" class="ai-result-block inner">
          <view class="ai-section-title">{{group.title}}</view>

          <view wx:for="{{group.tools}}" wx:key="name" wx:for-item="tool" class="mcp-skill-card">
            <view class="mcp-skill-head">
              <view class="mcp-skill-main">
                <view class="mcp-skill-title">{{tool.display_name}}</view>
                <view class="mcp-skill-summary">{{tool.summary}}</view>
              </view>
              <view class="mcp-skill-status tone-{{tool.statusTone}}">{{tool.statusText}}</view>
            </view>

            <view class="mcp-skill-actions">
              <button class="secondary-btn mcp-skill-btn" data-tool="{{tool.name}}" loading="{{mcpLoading && mcpActiveSkill === tool.name}}" disabled="{{mcpLoading || tool.disabled}}" bindtap="runMcpSkill">立即使用</button>
              <button class="ghost-btn mcp-skill-btn ghost" data-tool="{{tool.name}}" bindtap="toggleMcpSkillCard">{{tool.expanded ? '收起参数' : '填写参数'}}</button>
              <button class="ghost-btn mcp-skill-btn ghost" data-tool="{{tool.name}}" bindtap="toggleMcpSkillDescription">{{tool.collapsedDescription ? '展开说明' : '收起说明'}}</button>
            </view>

            <view wx:if="{{!tool.collapsedDescription}}" class="mcp-skill-detail">
              <view class="ai-card-text">{{tool.details}}</view>
              <view wx:if="{{tool.result_preview_hint}}" class="ai-card-tip">结果预期：{{tool.result_preview_hint}}</view>
              <view wx:if="{{tool.permissions && tool.permissions.length}}" class="ai-card-tip">所需能力：{{tool.permissions_text}}</view>
            </view>

            <view wx:if="{{tool.expanded}}" class="mcp-skill-form">
              <view wx:if="{{!tool.formFields.length}}" class="ai-card-tip">这个技能不需要额外参数，可以直接运行。</view>

              <view wx:for="{{tool.formFields}}" wx:key="name" wx:for-item="field" class="mcp-field-row">
                <view class="mcp-field-label">{{field.label}}{{field.required ? ' *' : ''}}</view>

                <block wx:if="{{field.enumOptions && field.enumOptions.length}}">
                  <view class="ai-chip-row wrap">
                    <view
                      wx:for="{{field.enumOptions}}"
                      wx:key="*this"
                      wx:for-item="option"
                      class="ai-choice {{option === field.value ? 'active' : ''}}"
                      data-tool="{{tool.name}}"
                      data-field="{{field.name}}"
                      data-value="{{option}}"
                      bindtap="handleMcpEnumSelect"
                    >{{option}}</view>
                  </view>
                </block>

                <switch
                  wx:if="{{field.type === 'boolean'}}"
                  checked="{{field.value}}"
                  data-tool="{{tool.name}}"
                  data-field="{{field.name}}"
                  bindchange="handleMcpFieldSwitch"
                />

                <textarea
                  wx:if="{{field.type === 'array'}}"
                  class="ai-textarea compact"
                  value="{{field.value}}"
                  placeholder="{{field.placeholder}}"
                  data-tool="{{tool.name}}"
                  data-field="{{field.name}}"
                  bindinput="handleMcpFieldInput"
                />

                <input
                  wx:if="{{field.type !== 'boolean' && field.type !== 'array' && !(field.enumOptions && field.enumOptions.length)}}"
                  class="ai-input"
                  value="{{field.value}}"
                  placeholder="{{field.placeholder}}"
                  data-tool="{{tool.name}}"
                  data-field="{{field.name}}"
                  bindinput="handleMcpFieldInput"
                />

                <view wx:if="{{field.error}}" class="mcp-field-error">{{field.error}}</view>
              </view>
            </view>
          </view>
        </view>

        <view wx:if="{{mcpResultCard}}" class="ai-result-block inner">
          <view wx:if="{{mcpResultCard.runtime_summary && mcpResultCard.runtime_summary.summary}}" class="ai-status-banner {{mcpResultCard.runtime_summary.degraded ? 'warning' : 'success'}}">
            <view class="ai-status-title">{{mcpResultCard.runtime_summary.status_text || '已完成'}}</view>
            <view class="ai-status-text">{{mcpResultCard.runtime_summary.summary}}</view>
          </view>
          <view class="ai-result-title">{{mcpResultCard.title}}</view>
          <view class="ai-result-text">{{mcpResultCard.summary}}</view>
          <view class="ai-result-block ai-collapsible-card">
            <view class="ai-collapsible-head" bindtap="toggleMcpResultDetails">
              <view>
                <view class="ai-result-title">查看技能依据</view>
                <view class="ai-card-tip">运行轨迹和证据链默认收起，不影响直接使用。</view>
              </view>
              <view class="ai-collapse-indicator">{{mcpResultDetailsCollapsed ? '展开' : '收起'}}</view>
            </view>

            <block wx:if="{{!mcpResultDetailsCollapsed}}">
              <view wx:if="{{mcpResultCard.langchain_trace && mcpResultCard.langchain_trace.length}}" class="ai-card-row">
                <view class="ai-card-title">运行轨迹</view>
                <view wx:for="{{mcpResultCard.langchain_trace}}" wx:key="index" class="ai-log-line">{{item.line}}</view>
              </view>
              <ai-evidence evidence="{{mcpResultCard.evidence}}" title="技能证据区" />
            </block>
          </view>
        </view>

        <view wx:if="{{activeRunDetail && mcpDemoResult && activeRunDetail.run_id === mcpDemoResult.run_id}}" class="ai-result-block inner ai-runtime-row">
          <view class="ai-collapsible-head" bindtap="toggleAiRuntimeCollapsed">
            <view>
              <view class="ai-result-title">运行态</view>
              <view class="ai-card-tip">{{activeRunDetail.runtime_summary.status_text || activeRunDetail.status_text || '进行中'}}</view>
            </view>
            <view class="ai-collapse-indicator">{{aiRuntimeCollapsed ? '展开' : '收起'}}</view>
          </view>
          <view class="ai-grid-two">
            <view class="ai-metric-card">
              <view class="ai-metric-label">当前智能体</view>
              <view class="ai-metric-value small">{{activeRunDetail.current_agent || activeRunDetail.runtime_summary.active_agent || '--'}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">步骤数</view>
              <view class="ai-metric-value">{{activeRunDetail.runtime_summary.step_count || activeRunSteps.length || 0}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">审批状态</view>
              <view class="ai-metric-value small">{{activeRunDetail.approval_state || 'not_required'}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">运行状态</view>
              <view class="ai-metric-value small">{{activeRunDetail.runtime_summary.status_text || activeRunDetail.status || '--'}}</view>
            </view>
          </view>
          <view class="button-row">
            <button class="ghost-btn" size="mini" data-action="refresh" bindtap="handleAiRuntimeAction">刷新</button>
            <button class="ghost-btn" size="mini" data-action="retry" bindtap="handleAiRuntimeAction">重试</button>
            <button class="ghost-btn" size="mini" data-action="resume" bindtap="handleAiRuntimeAction">恢复</button>
            <button class="ghost-btn" size="mini" data-action="cancel" bindtap="handleAiRuntimeAction">取消</button>
            <button wx:if="{{activeRunDetail.approval_state === 'pending'}}" class="secondary-btn" size="mini" data-action="approve" bindtap="handleAiRuntimeAction">批准</button>
            <button wx:if="{{activeRunDetail.approval_state === 'pending'}}" class="ghost-btn" size="mini" data-action="reject" bindtap="handleAiRuntimeAction">拒绝</button>
          </view>
          <block wx:if="{{!aiRuntimeCollapsed}}">
            <view wx:if="{{activeRunDetail.runtime_summary.summary}}" class="ai-card-row">
              <view class="ai-card-title">运行摘要</view>
              <view class="ai-card-text">{{activeRunDetail.runtime_summary.summary}}</view>
            </view>
            <view wx:if="{{activeRunSteps.length}}" class="ai-card-row">
              <view class="ai-card-title">步骤时间线</view>
              <view wx:for="{{activeRunSteps}}" wx:key="id" class="ai-card-row app-inner-card">
                <view class="ai-card-tip">#{{item.step_index}} {{item.title}}</view>
                <view class="ai-card-tip">{{item.agent_name || item.step_kind}} · {{item.status}} · {{item.latency_ms || 0}}ms</view>
                <view wx:if="{{item.summary}}" class="ai-card-text">{{item.summary}}</view>
              </view>
            </view>
            <view wx:if="{{activeRunArtifacts.length}}" class="ai-card-row">
              <view class="ai-card-title">运行产物</view>
              <view wx:for="{{activeRunArtifacts}}" wx:key="id" class="ai-card-row app-inner-card">
                <view class="ai-card-tip">{{item.title}}</view>
                <view class="ai-card-tip">{{item.artifact_type}}</view>
                <view wx:if="{{item.summary}}" class="ai-card-text">{{item.summary}}</view>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{mcpDemoError}}" class="ai-error-panel">
          <view class="ai-error-title">{{mcpDemoError.title}}</view>
          <view class="ai-error-message">{{mcpDemoError.message}}</view>
          <view class="ai-card-tip">详细报错已收纳在下方高级调试区。</view>
        </view>

        <view class="ai-result-block ai-collapsible-card" wx:if="{{mcpManifest.advanced_available}}">
          <view class="ai-collapsible-head" bindtap="toggleMcpAdvanced">
            <view>
              <view class="ai-result-title">高级调试</view>
              <view class="ai-card-tip">协议元信息、资源读取、提示词和原始 JSON 调试都保留在这里。</view>
            </view>
            <view class="ai-collapse-indicator">{{mcpAdvancedCollapsed ? '展开' : '收起'}}</view>
          </view>

          <block wx:if="{{!mcpAdvancedCollapsed}}">
            <view class="ai-grid-two">
              <view class="ai-metric-card">
                <view class="ai-metric-label">服务名</view>
                <view class="ai-metric-value small">{{mcpManifest.name}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">版本</view>
                <view class="ai-metric-value">{{mcpManifest.version}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">传输方式</view>
                <view class="ai-metric-value small">{{mcpManifest.transport_modes_text}}</view>
              </view>
              <view class="ai-metric-card">
                <view class="ai-metric-label">STDIO</view>
                <view class="ai-metric-value small">{{mcpManifest.mcp_stdio_available ? '可用' : '未启用'}}</view>
              </view>
            </view>

            <view wx:if="{{mcpManifest.stdio_command}}" class="ai-card-row">
              <view class="ai-card-title">STDIO 启动命令</view>
              <view class="ai-card-text">{{mcpManifest.stdio_command}}</view>
              <view class="ai-card-tip">HTTP 继续给小程序使用，STDIO 用于 MCP 客户端 / IDE。</view>
            </view>

            <view class="ai-section-title">原始工具调试</view>
            <view class="ai-card-row">
              <view class="ai-card-title">{{mcpDemoTool}}</view>
              <view class="ai-card-text">保留原始 JSON 调试入口，方便你继续做协议级测试。</view>
              <view wx:if="{{mcpDemoToolSchema}}" class="ai-card-tip">当前工具 schema：{{mcpDemoToolSchemaHint}}</view>
              <view wx:if="{{mcpDemoToolSchemaFields.length}}" class="ai-chip-row wrap">
                <view wx:for="{{mcpDemoToolSchemaFields}}" wx:key="name" class="ai-choice active">{{item.name}} · {{item.type}}{{item.required ? ' · 必填' : ''}}</view>
              </view>
              <view class="ai-chip-row wrap" wx:if="{{mcpDemoToolOptions.length}}">
                <view
                  wx:for="{{mcpDemoToolOptions}}"
                  wx:key="name"
                  class="{{item.className}}"
                  data-tool="{{item.name}}"
                  bindtap="handleMcpDemoToolSelect"
                >{{item.name}}</view>
              </view>
              <view class="ai-error-block">
                <view class="ai-error-label">当前发送参数</view>
                <textarea class="ai-textarea compact ai-code-input" value="{{mcpDemoToolArgsText}}" bindinput="handleMcpToolArgsInput" />
              </view>
              <button class="secondary-btn full-btn ai-inline-btn" loading="{{mcpLoading}}" disabled="{{mcpLoading}}" bindtap="runMcpDemoTool">运行原始 MCP 调试</button>
            </view>

            <view class="ai-section-title">MCP 资源读取</view>
            <view class="ai-card-row">
              <view class="ai-card-text">直接通过资源 URI 读取真实数据，而不只是看资源列表。</view>
              <view class="ai-chip-row wrap" wx:if="{{mcpResourceExamples.length}}">
                <view
                  wx:for="{{mcpResourceExamples}}"
                  wx:key="uri"
                  class="{{item.className}}"
                  data-uri="{{item.uri}}"
                  bindtap="handleMcpResourceExampleSelect"
                >{{item.label}}</view>
              </view>
              <input class="ai-input" value="{{mcpResourceUri}}" bindinput="handleMcpResourceUri" />
              <button class="secondary-btn full-btn ai-inline-btn" loading="{{mcpResourceLoading}}" disabled="{{mcpResourceLoading}}" bindtap="runMcpResourceDemo">读取 MCP 资源</button>
            </view>

            <view wx:if="{{mcpResourceError}}" class="ai-error-panel">
              <view class="ai-error-title">{{mcpResourceError.title}}</view>
              <view class="ai-error-message">{{mcpResourceError.message}}</view>
            </view>

            <view wx:if="{{mcpResourceResult}}" class="ai-result-block inner">
              <view class="ai-result-title">{{mcpResourceResult.name}}</view>
              <view class="ai-card-text">{{mcpResourceResult.uri}}</view>
              <view wx:if="{{mcpResourceResult.description}}" class="ai-card-tip">{{mcpResourceResult.description}}</view>
              <view class="ai-card-row">
                <view class="ai-card-title">资源类型</view>
                <view class="ai-card-text">{{mcpResourceResult.resource_type}}</view>
              </view>
              <view class="ai-card-row">
                <view class="ai-card-title">读取结果预览</view>
                <view class="ai-card-text">{{mcpResourceResult.item.nickname || mcpResourceResult.item.profile_summary || mcpResourceResult.item.title || '已成功读取资源数据'}}</view>
              </view>
            </view>

            <view class="ai-section-title">提示词列表</view>
            <view wx:for="{{mcpManifest.prompts}}" wx:key="name" class="ai-card-row">
              <view class="ai-card-title">{{item.name}}</view>
              <view class="ai-card-text">{{item.description}}</view>
            </view>

            <view class="ai-section-title">资源列表</view>
            <view wx:for="{{mcpManifest.resources}}" wx:key="uri" class="ai-card-row">
              <view class="ai-card-title">{{item.uri}}</view>
              <view class="ai-card-text">{{item.name}}</view>
            </view>

            <view wx:if="{{mcpDemoError}}" class="ai-result-block ai-collapsible-card">
              <view class="ai-collapsible-head" bindtap="toggleMcpDebugError">
                <view>
                  <view class="ai-result-title">原始错误详情</view>
                  <view class="ai-card-tip">请求参数、字段错误和后端返回会收纳在这里。</view>
                </view>
                <view class="ai-collapse-indicator">{{mcpDebugErrorCollapsed ? '展开' : '收起'}}</view>
              </view>

              <block wx:if="{{!mcpDebugErrorCollapsed}}">
                <view class="ai-error-panel">
                  <view class="ai-error-title">{{mcpDemoError.title}}</view>
                  <view class="ai-error-message">{{mcpDemoError.message}}</view>
                  <view wx:if="{{mcpDemoError.code}}" class="ai-error-meta">状态 / 代码：{{mcpDemoError.code}}</view>
                  <view class="ai-error-block">
                    <view class="ai-error-label">请求参数</view>
                    <view class="ai-error-code">{{mcpDemoError.requestText}}</view>
                  </view>
                  <view wx:if="{{mcpDemoError.fieldErrorsText}}" class="ai-error-block">
                    <view class="ai-error-label">字段错误</view>
                    <view class="ai-error-code">{{mcpDemoError.fieldErrorsText}}</view>
                  </view>
                  <view wx:if="{{mcpDemoError.responseText}}" class="ai-error-block">
                    <view class="ai-error-label">后端返回</view>
                    <view class="ai-error-code">{{mcpDemoError.responseText}}</view>
                  </view>
                </view>
              </block>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'apps'}}" class="section panel-card">
      <view class="card-title">AI 应用工作台</view>
      <view class="card-subtitle">这里不再只是说明卡片，而是把语法、写作、翻译、情景对话和连续会话都变成真实可操作的体验入口。</view>
      <button class="primary-btn full-btn ai-action" loading="{{appsLoading}}" disabled="{{appsLoading}}" bindtap="loadApplications">刷新应用数据</button>

      <view class="ai-workspace-tabs">
        <view class="ai-workspace-tab {{appWorkspaceTab === 'grammar' ? 'active' : ''}}" data-tab="grammar" bindtap="switchAppWorkspace">语法问答</view>
        <view class="ai-workspace-tab {{appWorkspaceTab === 'writing_prompt' ? 'active' : ''}}" data-tab="writing_prompt" bindtap="switchAppWorkspace">写作题目</view>
        <view class="ai-workspace-tab {{appWorkspaceTab === 'writing_correct' ? 'active' : ''}}" data-tab="writing_correct" bindtap="switchAppWorkspace">写作批改</view>
        <view class="ai-workspace-tab {{appWorkspaceTab === 'translation' ? 'active' : ''}}" data-tab="translation" bindtap="switchAppWorkspace">翻译训练</view>
        <view class="ai-workspace-tab {{appWorkspaceTab === 'scenario' ? 'active' : ''}}" data-tab="scenario" bindtap="switchAppWorkspace">情景对话</view>
        <view class="ai-workspace-tab {{appWorkspaceTab === 'conversation' ? 'active' : ''}}" data-tab="conversation" bindtap="switchAppWorkspace">连续会话</view>
      </view>

      <view wx:if="{{grammarGuide}}" class="ai-result-block">
        <view class="ai-result-title">{{grammarGuide.headline}}</view>
        <view class="ai-result-text">{{grammarGuide.summary}}</view>
        <view wx:if="{{grammarGuide.context_sources_text}}" class="ai-card-tip">上下文：{{grammarGuide.context_sources_text}}</view>
      </view>

      <view wx:if="{{agentsBrief}}" class="ai-result-block">
        <view class="ai-result-title">{{agentsBrief.headline}}</view>
        <view wx:for="{{agentsBrief.agents}}" wx:key="name" class="ai-card-row">
          <view class="ai-card-title">{{item.name}}</view>
          <view class="ai-card-text">{{item.focus}}</view>
          <view class="ai-card-tip">{{item.action}}</view>
        </view>
        <view wx:if="{{agentsBrief.recommended_flow.length}}" class="ai-card-row">
          <view class="ai-card-title">协作流</view>
          <view wx:for="{{agentsBrief.recommended_flow}}" wx:key="index" class="ai-bullet">{{item}}</view>
        </view>
      </view>

      <view wx:if="{{report}}" class="ai-result-block">
        <view class="ai-result-title">{{report.summary.headline || report.title}}</view>
        <view class="ai-result-text">{{report.summary.summary}}</view>
      </view>

      <view wx:if="{{appWorkspaceTab === 'grammar'}}" class="ai-result-block">
        <view class="ai-result-title">语法问答 / 语法导学</view>
        <view class="ai-card-text">输入一个句子，AI 会结合语法点和相似例句给出解释；你也可以继续追问某个具体困惑。</view>
        <textarea class="ai-textarea compact" value="{{appGrammarSentence}}" bindinput="handleAppGrammarSentence" maxlength="500" />
        <input class="ai-input" placeholder="可选：想追问的点，例如为什么这里用 who" value="{{appGrammarQuestion}}" bindinput="handleAppGrammarQuestion" />
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{appQueryLoading}}" disabled="{{appQueryLoading}}" bindtap="runGrammarTutor">运行语法问答</button>

        <view wx:if="{{appGrammarResult}}" class="ai-result-block inner">
          <view class="ai-result-title">{{appGrammarResult.headline}}</view>
          <view class="ai-result-text">{{appGrammarResult.summary}}</view>
          <view wx:if="{{appGrammarResult.tutor.explanation_cn}}" class="ai-card-row">
            <view class="ai-card-title">讲解</view>
            <view class="ai-card-text">{{appGrammarResult.tutor.explanation_cn}}</view>
            <view wx:if="{{appGrammarResult.tutor.coach_tip}}" class="ai-card-tip">{{appGrammarResult.tutor.coach_tip}}</view>
          </view>
          <view wx:if="{{appGrammarResult.tutor.recommended_focus && appGrammarResult.tutor.recommended_focus.length}}" class="ai-card-row">
            <view class="ai-card-title">建议先看</view>
            <view wx:for="{{appGrammarResult.tutor.recommended_focus}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <view wx:if="{{appGrammarResult.context_sources.length}}" class="ai-card-row">
            <view class="ai-card-title">本次参考上下文</view>
            <view wx:for="{{appGrammarResult.context_sources}}" wx:key="key" class="ai-card-tip">{{item.label}} · {{item.detail}}</view>
          </view>
          <view wx:if="{{appGrammarResult.langchain_trace.length}}" class="ai-card-row">
            <view class="ai-card-title">运行轨迹</view>
            <view wx:for="{{appGrammarResult.langchain_trace}}" wx:key="index" class="ai-log-line">{{item.line}}</view>
          </view>
          <ai-evidence evidence="{{appGrammarResult.evidence}}" title="语法问答证据区" />
        </view>
      </view>

      <view wx:if="{{appWorkspaceTab === 'writing_prompt'}}" class="ai-result-block">
        <view class="ai-result-title">写作题目生成</view>
        <view class="ai-chip-row wrap">
          <view class="ai-choice {{appWritingLevel === 'cet4' ? 'active' : ''}}" data-value="cet4" bindtap="handleAppWritingLevel">CET4</view>
          <view class="ai-choice {{appWritingLevel === 'cet6' ? 'active' : ''}}" data-value="cet6" bindtap="handleAppWritingLevel">CET6</view>
          <view class="ai-choice {{appWritingLevel === 'ielts' ? 'active' : ''}}" data-value="ielts" bindtap="handleAppWritingLevel">IELTS</view>
        </view>
        <view class="ai-chip-row wrap">
          <view class="ai-choice {{appWritingGenre === 'essay' ? 'active' : ''}}" data-value="essay" bindtap="handleAppWritingGenre">议论文</view>
          <view class="ai-choice {{appWritingGenre === 'letter' ? 'active' : ''}}" data-value="letter" bindtap="handleAppWritingGenre">书信</view>
          <view class="ai-choice {{appWritingGenre === 'report' ? 'active' : ''}}" data-value="report" bindtap="handleAppWritingGenre">报告</view>
        </view>
        <input class="ai-input" value="{{appWritingTopic}}" bindinput="handleAppWritingTopic" />
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{appQueryLoading}}" disabled="{{appQueryLoading}}" bindtap="runWritingPrompt">生成写作任务</button>

        <view wx:if="{{appWritingPromptResult}}" class="ai-result-block inner">
          <view class="ai-result-title">{{appWritingPromptResult.headline}}</view>
          <view class="ai-result-text">{{appWritingPromptResult.summary}}</view>
          <view wx:if="{{appWritingPromptResult.result.writing_goals && appWritingPromptResult.result.writing_goals.length}}" class="ai-card-row">
            <view class="ai-card-title">写作目标</view>
            <view wx:for="{{appWritingPromptResult.result.writing_goals}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <view wx:if="{{appWritingPromptResult.result.outline && appWritingPromptResult.result.outline.length}}" class="ai-card-row">
            <view class="ai-card-title">提纲</view>
            <view wx:for="{{appWritingPromptResult.result.outline}}" wx:key="section" class="ai-card-tip">{{item.section}} · {{item.guidance}}</view>
          </view>
          <view wx:if="{{appWritingPromptResult.result.sample_essay}}" class="ai-card-row">
            <view class="ai-card-title">示范范文</view>
            <view class="ai-card-text">{{appWritingPromptResult.result.sample_essay}}</view>
          </view>
          <view wx:if="{{appWritingPromptResult.result.scoring_rubric && appWritingPromptResult.result.scoring_rubric.length}}" class="ai-card-row">
            <view class="ai-card-title">评分维度</view>
            <view wx:for="{{appWritingPromptResult.result.scoring_rubric}}" wx:key="dimension" class="ai-card-tip">{{item.dimension}} · {{item.points}} · {{item.focus}}</view>
          </view>
          <view wx:if="{{appWritingPromptResult.linked_words_text}}" class="ai-card-row">
            <view class="ai-card-title">关联词汇</view>
            <view class="ai-card-text">{{appWritingPromptResult.linked_words_text}}</view>
          </view>
          <ai-evidence evidence="{{appWritingPromptResult.evidence}}" title="写作题目证据区" />
        </view>
      </view>

      <view wx:if="{{appWorkspaceTab === 'writing_correct'}}" class="ai-result-block">
        <view class="ai-result-title">写作批改</view>
        <view class="ai-card-text">把一小段英文写作粘进来，AI 会给出整体反馈、逐句问题和修改建议。</view>
        <textarea class="ai-textarea" value="{{appWritingText}}" bindinput="handleAppWritingText" maxlength="3000" />
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{appQueryLoading}}" disabled="{{appQueryLoading}}" bindtap="runWritingCorrect">开始批改</button>

        <view wx:if="{{appWritingCorrectResult}}" class="ai-result-block inner">
          <view class="ai-result-title">{{appWritingCorrectResult.headline}}</view>
          <view class="ai-result-text">{{appWritingCorrectResult.summary}}</view>
          <view class="ai-grid-two">
            <view class="ai-metric-card">
              <view class="ai-metric-label">分数</view>
              <view class="ai-metric-value">{{appWritingCorrectResult.result.score}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">评价</view>
              <view class="ai-metric-value small">{{appWritingCorrectResult.result.level}}</view>
            </view>
          </view>
          <view wx:if="{{appWritingCorrectResult.result.corrected_text}}" class="ai-card-row">
            <view class="ai-card-title">修改后版本</view>
            <view class="ai-card-text">{{appWritingCorrectResult.result.corrected_text}}</view>
          </view>
          <view wx:if="{{appWritingCorrectResult.result.sentence_feedback && appWritingCorrectResult.result.sentence_feedback.length}}" class="ai-card-row">
            <view class="ai-card-title">逐句反馈</view>
            <view wx:for="{{appWritingCorrectResult.result.sentence_feedback}}" wx:key="index" class="ai-card-row app-inner-card">
              <view class="ai-card-tip">原句：{{item.original}}</view>
              <view class="ai-card-tip">修改：{{item.corrected}}</view>
              <view class="ai-card-text">{{item.issue}}</view>
              <view class="ai-card-tip">{{item.explanation}}</view>
            </view>
          </view>
          <view wx:if="{{appWritingCorrectResult.result.suggestions && appWritingCorrectResult.result.suggestions.length}}" class="ai-card-row">
            <view class="ai-card-title">整体建议</view>
            <view wx:for="{{appWritingCorrectResult.result.suggestions}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <ai-evidence evidence="{{appWritingCorrectResult.evidence}}" title="写作批改证据区" />
        </view>
      </view>

      <view wx:if="{{appWorkspaceTab === 'translation'}}" class="ai-result-block">
        <view class="ai-result-title">翻译训练</view>
        <textarea class="ai-textarea compact" value="{{appTranslationSource}}" bindinput="handleAppTranslationSource" maxlength="1200" />
        <textarea class="ai-textarea compact" value="{{appTranslationUserAnswer}}" bindinput="handleAppTranslationUserAnswer" maxlength="1200" placeholder="把你的译文填在这里，留空也可以让 AI 先给参考方向" />
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{appQueryLoading}}" disabled="{{appQueryLoading}}" bindtap="runTranslationEvaluate">运行翻译训练</button>

        <view wx:if="{{appTranslationResult}}" class="ai-result-block inner">
          <view class="ai-result-title">{{appTranslationResult.headline}}</view>
          <view class="ai-result-text">{{appTranslationResult.summary}}</view>
          <view class="ai-grid-two">
            <view class="ai-metric-card">
              <view class="ai-metric-label">方向</view>
              <view class="ai-metric-value small">{{appTranslationResult.result.direction}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">分数</view>
              <view class="ai-metric-value">{{appTranslationResult.result.score}}</view>
            </view>
          </view>
          <view wx:if="{{appTranslationResult.result.reference_translation}}" class="ai-card-row">
            <view class="ai-card-title">参考译文</view>
            <view class="ai-card-text">{{appTranslationResult.result.reference_translation}}</view>
          </view>
          <view wx:if="{{appTranslationResult.result.accuracy_notes && appTranslationResult.result.accuracy_notes.length}}" class="ai-card-row">
            <view class="ai-card-title">准确性</view>
            <view wx:for="{{appTranslationResult.result.accuracy_notes}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <view wx:if="{{appTranslationResult.result.naturalness_notes && appTranslationResult.result.naturalness_notes.length}}" class="ai-card-row">
            <view class="ai-card-title">自然度</view>
            <view wx:for="{{appTranslationResult.result.naturalness_notes}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <view wx:if="{{appTranslationResult.result.grammar_notes && appTranslationResult.result.grammar_notes.length}}" class="ai-card-row">
            <view class="ai-card-title">语法提醒</view>
            <view wx:for="{{appTranslationResult.result.grammar_notes}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <ai-evidence evidence="{{appTranslationResult.evidence}}" title="翻译训练证据区" />
        </view>
      </view>

      <view wx:if="{{appWorkspaceTab === 'scenario'}}" class="ai-result-block">
        <view class="ai-result-title">情景对话</view>
        <view class="ai-chip-row wrap">
          <view wx:for="{{appScenarioTemplates}}" wx:key="scenario" class="ai-choice {{appScenario === item.scenario ? 'active' : ''}}" data-value="{{item.scenario}}" bindtap="handleAppScenario">{{item.label}}</view>
        </view>
        <textarea class="ai-textarea compact" value="{{appScenarioMessage}}" bindinput="handleAppScenarioMessage" maxlength="1000" />
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{appQueryLoading}}" disabled="{{appQueryLoading}}" bindtap="runScenarioDialogue">开始情景对话</button>

        <view wx:if="{{appScenarioResult}}" class="ai-result-block inner">
          <view class="ai-result-title">{{appScenarioResult.headline}}</view>
          <view class="ai-result-text">{{appScenarioResult.summary}}</view>
          <view wx:if="{{appScenarioResult.result.mission}}" class="ai-card-row">
            <view class="ai-card-title">本轮任务</view>
            <view class="ai-card-text">{{appScenarioResult.result.mission}}</view>
          </view>
          <view wx:if="{{appScenarioResult.result.coach_focus}}" class="ai-card-row">
            <view class="ai-card-title">教练关注点</view>
            <view class="ai-card-text">{{appScenarioResult.result.coach_focus}}</view>
          </view>
          <view wx:if="{{appScenarioResult.result.correction}}" class="ai-card-row">
            <view class="ai-card-title">即时修正</view>
            <view class="ai-card-tip">{{appScenarioResult.result.correction.corrected}}</view>
            <view wx:for="{{appScenarioResult.result.correction.notes}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <view wx:if="{{appScenarioResult.result.next_suggestions && appScenarioResult.result.next_suggestions.length}}" class="ai-card-row">
            <view class="ai-card-title">下一句可以怎么接</view>
            <view wx:for="{{appScenarioResult.result.next_suggestions}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <ai-evidence evidence="{{appScenarioResult.evidence}}" title="情景对话证据区" />
        </view>
      </view>

      <view wx:if="{{appWorkspaceTab === 'conversation'}}" class="ai-result-block">
        <view class="ai-result-title">连续会话 / 再次追问</view>
        <view class="ai-card-text">这里把 RAG 问答、学习解释和追问历史串起来，方便查看连续会话。</view>
        <view class="ai-chip-row wrap">
          <view class="ai-choice {{appConversationFeatureType === 'rag' ? 'active' : ''}}" data-value="rag" bindtap="handleConversationFeatureType">RAG 问答</view>
          <view class="ai-choice {{appConversationFeatureType === 'grammar' ? 'active' : ''}}" data-value="grammar" bindtap="handleConversationFeatureType">语法</view>
          <view class="ai-choice {{appConversationFeatureType === 'writing' ? 'active' : ''}}" data-value="writing" bindtap="handleConversationFeatureType">写作</view>
          <view class="ai-choice {{appConversationFeatureType === 'translation' ? 'active' : ''}}" data-value="translation" bindtap="handleConversationFeatureType">翻译</view>
        </view>
        <textarea class="ai-textarea compact" value="{{appConversationQuestion}}" bindinput="handleConversationQuestion" maxlength="1000" />
        <button class="secondary-btn full-btn ai-inline-btn" loading="{{appConversationLoading}}" disabled="{{appConversationLoading}}" bindtap="askConversation">发起会话</button>

        <view wx:if="{{appConversationAnswer}}" class="ai-result-block inner">
          <view wx:if="{{appConversationRuntime && appConversationRuntime.runtime_summary && appConversationRuntime.runtime_summary.summary}}" class="ai-status-banner {{appConversationRuntime.runtime_summary.degraded ? 'warning' : 'success'}}">
            <view class="ai-status-title">{{appConversationRuntime.runtime_summary.status_text || '已完成'}}</view>
            <view class="ai-status-text">{{appConversationRuntime.runtime_summary.summary}}</view>
          </view>
          <view class="ai-result-title">{{appConversationAnswer.headline}}</view>
          <view class="ai-result-text">{{appConversationAnswer.summary}}</view>
          <view wx:if="{{appConversationRuntime && appConversationRuntime.resolved_route}}" class="ai-card-tip">本轮路由：{{appConversationRuntime.resolved_route}}</view>
          <view wx:if="{{appConversationAnswer.answer_summary}}" class="ai-card-row">
            <view class="ai-card-title">回答摘要</view>
            <view class="ai-card-text">{{appConversationAnswer.answer_summary}}</view>
          </view>
          <view wx:if="{{appConversationAnswer.grounded_points.length}}" class="ai-card-row">
            <view class="ai-card-title">依据点</view>
            <view wx:for="{{appConversationAnswer.grounded_points}}" wx:key="index" class="ai-bullet">{{item}}</view>
          </view>
          <view wx:if="{{appConversationAnswer.tutor && appConversationAnswer.tutor.explanation_cn}}" class="ai-card-row">
            <view class="ai-card-title">讲解</view>
            <view class="ai-card-text">{{appConversationAnswer.tutor.explanation_cn}}</view>
          </view>
          <view wx:if="{{appConversationAnswer.result && appConversationAnswer.result.corrected_text}}" class="ai-card-row">
            <view class="ai-card-title">修改后版本</view>
            <view class="ai-card-text">{{appConversationAnswer.result.corrected_text}}</view>
          </view>
          <view wx:if="{{appConversationAnswer.result && appConversationAnswer.result.reference_translation}}" class="ai-card-row">
            <view class="ai-card-title">参考译文</view>
            <view class="ai-card-text">{{appConversationAnswer.result.reference_translation}}</view>
          </view>
          <view wx:if="{{appConversationAnswer.context_sources.length}}" class="ai-card-row">
            <view class="ai-card-title">本次上下文</view>
            <view wx:for="{{appConversationAnswer.context_sources}}" wx:key="key" class="ai-card-tip">{{item.label}} · {{item.detail}}</view>
          </view>
        </view>

        <view wx:if="{{activeRunDetail && appConversationRuntime && activeRunDetail.run_id === appConversationRuntime.run_id}}" class="ai-result-block inner ai-runtime-row">
          <view class="ai-collapsible-head" bindtap="toggleAiRuntimeCollapsed">
            <view>
              <view class="ai-result-title">会话运行态</view>
              <view class="ai-card-tip">{{activeRunDetail.runtime_summary.status_text || activeRunDetail.status_text || '进行中'}}</view>
            </view>
            <view class="ai-collapse-indicator">{{aiRuntimeCollapsed ? '展开' : '收起'}}</view>
          </view>
          <view class="ai-grid-two">
            <view class="ai-metric-card">
              <view class="ai-metric-label">当前智能体</view>
              <view class="ai-metric-value small">{{activeRunDetail.current_agent || activeRunDetail.runtime_summary.active_agent || '--'}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">步骤数</view>
              <view class="ai-metric-value">{{activeRunDetail.runtime_summary.step_count || activeRunSteps.length || 0}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">审批状态</view>
              <view class="ai-metric-value small">{{activeRunDetail.approval_state || 'not_required'}}</view>
            </view>
            <view class="ai-metric-card">
              <view class="ai-metric-label">运行状态</view>
              <view class="ai-metric-value small">{{activeRunDetail.runtime_summary.status_text || activeRunDetail.status || '--'}}</view>
            </view>
          </view>
          <block wx:if="{{!aiRuntimeCollapsed}}">
            <view wx:if="{{activeRunDetail.runtime_summary.summary}}" class="ai-card-row">
              <view class="ai-card-title">运行摘要</view>
              <view class="ai-card-text">{{activeRunDetail.runtime_summary.summary}}</view>
            </view>
            <view wx:if="{{activeRunSteps.length}}" class="ai-card-row">
              <view class="ai-card-title">步骤时间线</view>
              <view wx:for="{{activeRunSteps}}" wx:key="id" class="ai-log-line">{{item.agent_name}} · {{item.title}} · {{item.status}}</view>
            </view>
            <view class="button-row">
              <button class="ghost-btn ai-mini-btn" data-action="refresh" bindtap="handleAiRuntimeAction">刷新</button>
              <button wx:if="{{activeRunDetail.retryable}}" class="ghost-btn ai-mini-btn" data-action="retry" bindtap="handleAiRuntimeAction">重试</button>
              <button wx:if="{{activeRunDetail.runtime_summary.resumable}}" class="ghost-btn ai-mini-btn" data-action="resume" bindtap="handleAiRuntimeAction">恢复</button>
              <button wx:if="{{activeRunDetail.approval_state === 'pending'}}" class="ghost-btn ai-mini-btn" data-action="approve" bindtap="handleAiRuntimeAction">批准</button>
              <button wx:if="{{activeRunDetail.approval_state === 'pending'}}" class="ghost-btn ai-mini-btn" data-action="reject" bindtap="handleAiRuntimeAction">拒绝</button>
            </view>
          </block>
        </view>

        <view wx:if="{{appConversationId}}" class="ai-card-row">
          <view class="ai-card-title">继续追问</view>
          <input class="ai-input" value="{{appConversationFollowup}}" bindinput="handleConversationFollowup" placeholder="例如：那能再给我一个更容易记住的例句吗？" />
          <button class="secondary-btn full-btn ai-inline-btn" loading="{{appConversationFollowupLoading}}" disabled="{{appConversationFollowupLoading}}" bindtap="followupConversation">发送追问</button>
        </view>

        <view class="ai-grid-two ai-conversation-layout">
          <view class="ai-card-row">
            <view class="ai-card-title">最近会话</view>
            <view wx:if="{{!appConversationList.length}}" class="ai-card-text">还没有会话记录，先发起一次对话试试。</view>
            <view wx:for="{{appConversationList}}" wx:key="id" class="app-conversation-item {{appConversationId === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="selectConversation">
              <view class="app-conversation-title">{{item.title}}</view>
              <view class="app-conversation-meta">{{item.tagText}}</view>
            </view>
          </view>

          <view class="ai-card-row">
            <view class="ai-card-title">会话详情</view>
            <view wx:if="{{!appConversationDetail}}" class="ai-card-text">选中一条会话后，这里会展开完整消息历史。</view>
            <view wx:if="{{appConversationDetail}}">
              <view class="ai-card-tip">{{appConversationDetail.feature_label}} · {{appConversationDetail.message_count}} 条消息</view>
              <view class="ai-card-tip">{{appConversationDetail.title}}</view>
              <view wx:if="{{appConversationDetail.latest_runtime_run && appConversationDetail.latest_runtime_run.run_id}}" class="ai-card-tip">
                最近运行：{{appConversationDetail.latest_runtime_run.runtime_summary.status_text || appConversationDetail.latest_runtime_run.status}}
              </view>
              <view wx:for="{{appConversationDetail.messages}}" wx:key="id" class="app-message-card app-message-{{item.role}}">
                <view class="app-message-role">{{item.role}}</view>
                <view class="app-message-content">{{item.content}}</view>
                <view wx:if="{{item.metaText}}" class="app-message-meta">{{item.metaText}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'ops'}}" class="section panel-card">
      <view class="card-title">AI 观测与评测</view>
      <view class="card-subtitle">除了看结果，这里还能看运行路径、失败样本、单次评测详情和单条重放，方便把工程能力讲清楚。</view>
      <button class="primary-btn full-btn ai-action" loading="{{opsLoading}}" disabled="{{opsLoading}}" bindtap="loadObservability">刷新观测</button>
      <button class="secondary-btn full-btn ai-inline-btn" loading="{{evaluationRunning}}" bindtap="runEvaluations">运行 AI 评测</button>
      <button class="secondary-btn full-btn ai-inline-btn" loading="{{evaluationRunning}}" bindtap="replayFailedEvaluations">重放失败样本</button>

      <view wx:if="{{quality}}" class="ai-result-block">
        <view class="ai-result-title">质量摘要</view>
        <view class="ai-grid-two">
          <view class="ai-metric-card">
            <view class="ai-metric-label">近 7 天请求</view>
            <view class="ai-metric-value">{{quality.week_request_count}}</view>
          </view>
          <view class="ai-metric-card">
            <view class="ai-metric-label">缓存命中</view>
            <view class="ai-metric-value">{{quality.cache_hit_count}}</view>
          </view>
          <view class="ai-metric-card">
            <view class="ai-metric-label">活跃缓存</view>
            <view class="ai-metric-value">{{quality.active_cache_items}}</view>
          </view>
          <view class="ai-metric-card">
            <view class="ai-metric-label">消息总量</view>
            <view class="ai-metric-value">{{quality.message_count}}</view>
          </view>
        </view>
        <view wx:for="{{quality.quality_notes}}" wx:key="index" class="ai-bullet">{{item}}</view>
      </view>

      <view wx:if="{{observability}}" class="ai-result-block">
        <view class="ai-result-title">运行路径聚合</view>
        <view class="ops-path-grid">
          <view wx:for="{{observability.runtime_path_summary}}" wx:key="path" class="ops-path-card">
            <view class="ops-path-title">{{item.path}}</view>
            <view class="ops-path-value">{{item.total}}</view>
          </view>
        </view>

        <view class="ai-section-title">功能调用汇总</view>
        <view wx:for="{{observability.feature_summary}}" wx:key="feature_type" class="ai-card-row">
          <view class="ai-card-title">{{item.feature_type}}</view>
          <view class="ai-card-text">请求 {{item.total}} 次 · 缓存 {{item.cache_hits}} 次</view>
        </view>

        <view wx:if="{{observability.prompt_versions && observability.prompt_versions.length}}" class="ai-section-title">提示词版本对比</view>
        <view wx:for="{{observability.prompt_versions}}" wx:key="prompt_version" class="ai-card-row">
          <view class="ai-card-title">{{item.prompt_version}}</view>
          <view class="ai-card-text">请求 {{item.total}} 次</view>
        </view>

        <view wx:if="{{observability.model_summary && observability.model_summary.length}}" class="ai-section-title">模型使用概览</view>
        <view wx:for="{{observability.model_summary}}" wx:key="model_name" class="ai-card-row">
          <view class="ai-card-title">{{item.model_name}}</view>
          <view class="ai-card-text">请求 {{item.total}} 次</view>
        </view>

        <view class="ai-section-title">最近日志</view>
        <view wx:for="{{observability.recent_logs}}" wx:key="id" class="ai-card-row">
          <view class="ai-card-title">{{item.feature_type}}</view>
          <view class="ai-card-text">{{item.endpoint}} · {{item.latency_ms}} ms</view>
          <view class="ai-card-tip">{{item.status_text || item.status}} {{item.cache_hit ? '· 缓存命中' : ''}}</view>
          <view wx:if="{{item.prompt_version}}" class="ai-card-tip">提示词：{{item.prompt_version}}</view>
          <view wx:if="{{item.model_name}}" class="ai-card-tip">模型：{{item.model_name}}</view>
        </view>
      </view>

      <view wx:if="{{evaluationCases.length || evaluationRuns.length}}" class="ai-result-block">
        <view class="ai-result-title">AI 评测 / 失败回放</view>
        <view wx:for="{{evaluationCases}}" wx:key="id" class="ai-card-row">
          <view class="ai-card-title">{{item.name}}</view>
          <view class="ai-card-text">{{item.case_type}}</view>
          <view class="ai-card-tip">{{item.description}}</view>
        </view>

        <view wx:if="{{evaluationSummary}}" class="ai-card-row">
          <view class="ai-card-title">评测摘要</view>
          <view class="ai-card-text">最近 {{evaluationSummary.run_count || 0}} 次运行，pass rate {{evaluationSummary.pass_rate || 0}}%</view>
        </view>

        <view wx:if="{{evaluationSummary && evaluationSummary.regression_report && evaluationSummary.regression_report.length}}" class="ai-section-title">回归报告</view>
        <view wx:for="{{evaluationSummary.regression_report}}" wx:key="case_name" class="ai-card-row">
          <view class="ai-card-title">{{item.case_name}}</view>
          <view class="ai-card-text">最新 {{item.latest_status}} / {{item.latest_score}}</view>
          <view wx:if="{{item.previous_status}}" class="ai-card-tip">上次 {{item.previous_status}} / {{item.previous_score}}</view>
          <view wx:if="{{item.delta_score !== null}}" class="ai-card-tip">变化 {{item.delta_score}}</view>
        </view>

        <view class="ai-section-title">最近评测运行</view>
        <view wx:for="{{evaluationRuns}}" wx:key="id" class="ai-card-row">
          <view class="ai-card-title">{{item.case_name}}</view>
          <view class="ai-card-text">{{item.status}} · {{item.score}}</view>
          <view class="ai-card-tip">{{item.traceSummaryText}}</view>
          <view wx:if="{{item.failure_reason}}" class="ai-card-tip">{{item.failure_reason}}</view>
          <view class="button-row">
            <button class="ghost-btn ai-mini-btn" data-run-id="{{item.id}}" loading="{{evaluationRunDetailLoading && selectedEvaluationRun === item.id}}" bindtap="loadEvaluationRunDetail">查看详情</button>
            <button class="secondary-btn ai-mini-btn" data-run-id="{{item.id}}" loading="{{evaluationReplayLoading && selectedEvaluationRun === item.id}}" bindtap="replaySingleEvaluationRun">单条重放</button>
          </view>
        </view>
      </view>

      <view wx:if="{{evaluationRunDetail}}" class="ai-result-block">
        <view class="ai-result-title">单次评测详情</view>
        <view class="ai-card-row">
          <view class="ai-card-title">{{evaluationRunDetail.case_name}}</view>
          <view class="ai-card-text">{{evaluationRunDetail.status}} · {{evaluationRunDetail.score}}</view>
          <view class="ai-card-tip">{{evaluationRunDetail.traceSummaryText}}</view>
        </view>
        <view wx:if="{{evaluationRunDetail.failure_reason}}" class="ai-card-row">
          <view class="ai-card-title">失败原因</view>
          <view class="ai-card-text">{{evaluationRunDetail.failure_reason}}</view>
        </view>
        <view class="ai-json-card">
          <view class="ai-card-title">request_payload</view>
          <view class="ai-json-text">{{evaluationRunDetail.requestPayloadText}}</view>
        </view>
        <view class="ai-json-card">
          <view class="ai-card-title">result_payload</view>
          <view class="ai-json-text">{{evaluationRunDetail.resultPayloadText}}</view>
        </view>
        <view class="ai-json-card">
          <view class="ai-card-title">trace_payload</view>
          <view class="ai-json-text">{{evaluationRunDetail.tracePayloadText}}</view>
        </view>
        <view class="ai-json-card">
          <view class="ai-card-title">runtime_snapshot</view>
          <view class="ai-json-text">{{evaluationRunDetail.runtimeSnapshotText}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

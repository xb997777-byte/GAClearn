.evidence-block {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid var(--theme-card-border, #d5e5ff);
  background: rgba(255, 255, 255, 0.94);
}

.evidence-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.evidence-title {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--theme-text-primary, #0f2748);
}

.evidence-toggle {
  flex-shrink: 0;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-secondary-text, #0e60d8);
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.evidence-summary {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--theme-text-secondary, #55718f);
}

.evidence-section {
  margin-top: 18rpx;
}

.evidence-section-title {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--theme-secondary-text, #0e60d8);
}

.evidence-step {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.evidence-step-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-secondary-text, #0e60d8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.evidence-step-main {
  flex: 1;
  min-width: 0;
}

.evidence-step-name,
.evidence-card-title,
.evidence-metric-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-text-primary, #0f2748);
}

.evidence-step-detail,
.evidence-card-text,
.evidence-card-tip,
.evidence-code,
.evidence-metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--theme-text-secondary, #55718f);
  word-break: break-word;
}

.evidence-card {
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(247, 251, 255, 0.96);
}

.evidence-card-head,
.evidence-inline-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.evidence-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(44, 93, 255, 0.08);
  color: var(--theme-secondary-text, #0e60d8);
  font-size: 22rpx;
  font-weight: 700;
}

.evidence-chip-wide {
  max-width: 100%;
}

.evidence-code {
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(16, 24, 40, 0.05);
}

.evidence-metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 12rpx;
}

.evidence-metric {
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(44, 93, 255, 0.05);
}

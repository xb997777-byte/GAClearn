.grammar-page .search-btn,
.grammar-page .hero-entry-btn-text,
.grammar-page .module-entry-btn-text,
.grammar-page .volume-entry-btn-text {
  font-size: var(--theme-font-size-button);
}

.grammar-page .hub-hero,
.grammar-page .guide-hero,
.grammar-page .volume-hero,
.grammar-page .learning-hero {
  background:
    radial-gradient(circle at 12% 14%, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, var(--theme-primary-start) 0%, var(--theme-hero-end) 52%, var(--theme-accent) 100%);
}

.grammar-page .module-card,
.grammar-page .guide-path-card,
.grammar-page .volume-card,
.grammar-page .book-card,
.grammar-page .chapter-card,
.grammar-page .volume-preview-panel,
.grammar-page .chapter-block,
.grammar-page .example-card,
.grammar-page .volume-line,
.grammar-page .volume-goal,
.grammar-page .practice-card,
.grammar-page .summary-card,
.grammar-page .board-card,
.grammar-page .focus-card,
.grammar-page .guide-card,
.grammar-page .core-card,
.grammar-page .support-card {
  border-color: var(--theme-card-border);
  box-shadow: 0 14rpx 30rpx var(--theme-card-shadow);
}

.grammar-page .module-mark,
.grammar-page .path-index,
.grammar-page .volume-badge,
.grammar-page .book-source,
.grammar-page .chapter-no,
.grammar-page .chapter-toggle,
.grammar-page .detail-kicker,
.grammar-page .focus-role,
.grammar-page .support-role {
  background: var(--grammar-soft-bg);
  color: var(--grammar-soft-text);
}

.grammar-page .module-tag,
.grammar-page .volume-meta-chip,
.grammar-page .filter-chip,
.grammar-page .difficulty-chip,
.grammar-page .sample-chip {
  border-color: var(--theme-card-border);
}

.grammar-page .module-entry-btn,
.grammar-page .volume-entry-btn,
.grammar-page .hero-entry-btn {
  background: linear-gradient(135deg, var(--theme-primary-start) 0%, var(--theme-primary-end) 100%);
  box-shadow: 0 16rpx 30rpx var(--theme-card-shadow);
}

.grammar-page .hero-soft-btn {
  background: var(--theme-card-bg);
  color: var(--theme-accent);
}

.grammar-page .hero-ghost-btn {
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.24);
}

.grammar-page .module-entry-btn-text,
.grammar-page .volume-entry-btn-text,
.grammar-page .hero-entry-btn-text {
  color: #ffffff;
}

.grammar-page .module-subtitle,
.grammar-page .guide-path-desc,
.grammar-page .volume-subtitle,
.grammar-page .book-desc,
.grammar-page .chapter-desc,
.grammar-page .block-tag,
.grammar-page .mode-chip-text,
.grammar-page .summary-label,
.grammar-page .guide-note,
.grammar-page .core-note,
.grammar-page .focus-note,
.grammar-page .sentence-list-meta,
.grammar-page .volume-nav-text,
.grammar-page .section-tip {
  color: var(--theme-text-secondary);
}

.grammar-page .module-fit,
.grammar-page .volume-preview-text,
.grammar-page .chapter-block-text,
.grammar-page .chapter-line,
.grammar-page .path-text,
.grammar-page .reading-translation,
.grammar-page .summary-text,
.grammar-page .guide-cn,
.grammar-page .core-cn,
.grammar-page .focus-cn,
.grammar-page .support-cn,
.grammar-page .guide-en,
.grammar-page .core-en,
.grammar-page .support-en,
.grammar-page .focus-en,
.grammar-page .practice-question,
.grammar-page .practice-option {
  color: var(--theme-text-primary);
}

.grammar-page .module-fit,
.grammar-page .search-input,
.grammar-page .analyze-textarea,
.grammar-page .sample-chip,
.grammar-page .reading-translation,
.grammar-page .practice-option {
  background: var(--theme-card-bg);
  border-color: var(--theme-card-border);
}

.grammar-page .view-segmented {
  background: var(--theme-segmented-bg);
}

.grammar-page .view-segmented .segmented-item.active,
.grammar-page .filter-chip.active,
.grammar-page .difficulty-chip.active,
.grammar-page .practice-option.selected {
  background: var(--theme-primary-start);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 12rpx 24rpx var(--theme-card-shadow);
}

.grammar-page .mode-chip.complete {
  background: var(--theme-secondary-bg);
  color: var(--theme-secondary-text);
}

.grammar-page .mode-chip.core {
  background: var(--theme-chip-light-bg);
  color: var(--theme-chip-light-text);
}

.grammar-page .board-complete {
  background:
    radial-gradient(circle at 10% 12%, rgba(255, 255, 255, 0.64) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(180deg, var(--theme-page-start) 0%, #ffffff 100%);
  border-color: var(--theme-card-border);
}

.grammar-page .board-core {
  background:
    radial-gradient(circle at 10% 12%, rgba(255, 255, 255, 0.64) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(180deg, var(--theme-page-mid) 0%, #ffffff 100%);
  border-color: var(--theme-card-border);
}

.grammar-page .reading-translation {
  border-left-color: var(--theme-accent);
}

.grammar-page .progress-fill {
  background: linear-gradient(135deg, var(--theme-primary-start) 0%, var(--theme-primary-end) 100%);
}

.grammar-page .volume-line.warn,
.grammar-page .practice-result.error {
  border-color: #f4b183;
}

.grammar-page .volume-goal,
.grammar-page .practice-result.ok {
  border-color: #9ad7b0;
}

.motion-pop .hero-entry-btn,
.motion-pop .module-entry-btn,
.motion-pop .volume-entry-btn,
.motion-pop .chapter-head,
.motion-pop .guide-card,
.motion-pop .core-card,
.motion-pop .support-card {
  transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
}

.motion-glide .hero-entry-btn,
.motion-glide .module-entry-btn,
.motion-glide .volume-entry-btn,
.motion-glide .chapter-head,
.motion-glide .guide-card,
.motion-glide .core-card,
.motion-glide .support-card {
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.motion-sheet .hero-entry-btn,
.motion-sheet .module-entry-btn,
.motion-sheet .volume-entry-btn,
.motion-sheet .chapter-head,
.motion-sheet .guide-card,
.motion-sheet .core-card,
.motion-sheet .support-card {
  transition: transform 0.16s ease, opacity 0.16s ease, border-color 0.16s ease;
}

.motion-focus .hero-entry-btn,
.motion-focus .module-entry-btn,
.motion-focus .volume-entry-btn,
.motion-focus .chapter-head,
.motion-focus .guide-card,
.motion-focus .core-card,
.motion-focus .support-card {
  transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
}

.motion-float .hero-entry-btn,
.motion-float .module-entry-btn,
.motion-float .volume-entry-btn,
.motion-float .chapter-head,
.motion-float .guide-card,
.motion-float .core-card,
.motion-float .support-card {
  transition: transform 0.24s ease, box-shadow 0.24s ease, background-color 0.24s ease, border-color 0.24s ease;
}

.hover-card-pop {
  transform: translateY(-6rpx) scale(1.015);
  box-shadow: 0 20rpx 40rpx var(--theme-card-shadow);
}

.hover-action-bloom {
  transform: scale(0.98);
  opacity: 0.96;
}

.hover-card-slide {
  transform: translateX(8rpx);
  border-color: var(--theme-accent);
}

.hover-action-sweep {
  transform: translateY(-2rpx);
  box-shadow: 0 18rpx 34rpx var(--theme-card-shadow);
}

.hover-card-sheet {
  transform: rotate(-0.5deg) translateY(-4rpx);
  border-color: var(--theme-accent);
}

.hover-action-underline {
  transform: scaleX(0.985);
  opacity: 0.94;
}

.hover-card-focus {
  transform: translateY(-4rpx);
  box-shadow: 0 18rpx 38rpx var(--theme-card-shadow);
}

.hover-action-nudge {
  transform: translateX(8rpx);
}

.hover-card-float {
  transform: translateY(-8rpx) scale(1.012);
  box-shadow: 0 24rpx 46rpx var(--theme-card-shadow);
}

.hover-action-press {
  transform: translateY(-3rpx) scale(0.992);
  box-shadow: 0 20rpx 36rpx var(--theme-card-shadow);
}

.font-notebook .hub-title,
.font-notebook .guide-hero-title,
.font-notebook .volume-hero-title,

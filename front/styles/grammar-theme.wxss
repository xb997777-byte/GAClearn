.grammar-page {
  --grammar-outline: var(--theme-card-border);
  --grammar-accent: var(--theme-accent);
  --grammar-soft-bg: var(--theme-secondary-bg);
  --grammar-soft-text: var(--theme-secondary-text);
  --grammar-chip-bg: var(--theme-chip-light-bg);
  --grammar-chip-text: var(--theme-chip-light-text);
}

.grammar-page .hub-title,
.grammar-page .guide-hero-title,
.grammar-page .volume-hero-title,
.grammar-page .module-title,
.grammar-page .volume-title,
.grammar-page .chapter-title,
.grammar-page .detail-summary,
.grammar-page .block-title,
.grammar-page .guide-example-en,
.grammar-page .focus-en,
.grammar-page .summary-text.strong,
.grammar-page .theme-featured-name {
  font-family: var(--theme-font-display);
}

.grammar-page .hub-title,
.grammar-page .guide-hero-title,
.grammar-page .volume-hero-title {
  font-size: var(--theme-font-size-hero);
}

.grammar-page .module-title,
.grammar-page .volume-title,
.grammar-page .guide-path-title,
.grammar-page .book-title,
.grammar-page .chapter-title,
.grammar-page .detail-summary,
.grammar-page .block-title,
.grammar-page .guide-example-en,
.grammar-page .focus-en,
.grammar-page .summary-text.strong {
  font-size: var(--theme-font-size-grammar-title);
}

.grammar-page .module-subtitle,
.grammar-page .guide-path-desc,
.grammar-page .volume-subtitle,
.grammar-page .book-desc,
.grammar-page .chapter-desc,
.grammar-page .chapter-block-text,
.grammar-page .chapter-line,
.grammar-page .volume-preview-text,
.grammar-page .path-text,
.grammar-page .guide-cn,
.grammar-page .core-cn,
.grammar-page .focus-cn,
.grammar-page .support-cn,
.grammar-page .reading-translation,
.grammar-page .summary-text,
.grammar-page .practice-question,
.grammar-page .practice-option,
.grammar-page .volume-line,
.grammar-page .volume-goal,
.grammar-page .search-input,
.grammar-page .analyze-textarea {
